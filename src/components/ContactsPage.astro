---
import { type Lang, t, routeMap } from '../i18n/ui';
import ContactActions from './ContactActions.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Contatti del locale. Numero e WhatsApp vivono in ContactActions (fonte unica).
const EMAIL = 'biblio.bookcafe@gmail.com';
const IG_URL = 'https://www.instagram.com/biblio_treviso/';
const FB_URL = 'https://www.facebook.com/p/Biblio-100087459455523/';

// Google Maps embed (Via Armando Diaz 3/A, Treviso).
// Niente API key, usiamo l'URL embed pubblico, che è sufficiente per un iframe statico.
const mapsEmbedUrl = 'https://www.google.com/maps?q=Via+Armando+Diaz+3%2FA,+31100+Treviso+TV,+Italia&output=embed';
// Link "Apri in Google Maps" → indicazioni stradali verso il locale.
const mapsLinkUrl  = 'https://www.google.com/maps/dir/?api=1&destination=Via+Armando+Diaz+3%2FA,+31100+Treviso+TV,+Italia';

// Recensioni placeholder, realistiche ma fittizie. Da sostituire con reali post-lancio.
type Review = { name: string; meta: { it: string; en: string }; body: { it: string; en: string }; stars: 5 | 4 };
const reviews: Review[] = [
  {
    name: 'Marta P.',
    meta: { it: 'Recensione Google · Aprile 2026', en: 'Google review · April 2026' },
    stars: 5,
    body: {
      it: 'Posto magico. Sono andata per il giovedì jazz, sono rimasta fino a chiusura. Drink curatissimi, cicchetti ottimi, e un\'atmosfera da romanzo. La band del giovedì era da brividi.',
      en: 'A magical place. I came in for Thursday jazz and stayed till closing. Beautifully crafted drinks, excellent small plates, and a novel-like atmosphere. The Thursday band was unreal.',
    },
  },
  {
    name: 'Luca M.',
    meta: { it: 'Recensione Google · Marzo 2026', en: 'Google review · March 2026' },
    stars: 5,
    body: {
      it: 'Da anni il mio locale preferito a Treviso. La sera del venerdì la blues band fa muovere il bancone, ma anche i pomeriggi tranquilli con un libro funzionano benissimo. Personale gentile.',
      en: 'My favourite spot in Treviso for years. The Friday blues band gets the counter swinging, but the quiet afternoons with a book work just as well. Lovely staff.',
    },
  },
  {
    name: 'Elena e James',
    meta: { it: 'Visitatori da Londra · Febbraio 2026', en: 'Visiting from London · February 2026' },
    stars: 5,
    body: {
      it: 'Ci hanno consigliato Biblio in hotel e abbiamo capito perché. Lampade d\'epoca, libri ovunque, e un cantautore italiano dal vivo che ci ha conquistati. Da tornare.',
      en: 'Our hotel sent us to Biblio and now we get it. Vintage lamps, books everywhere, and an Italian songwriter live who completely won us over. We\'ll be back.',
    },
  },
  {
    name: 'Davide R.',
    meta: { it: 'Recensione Google · Gennaio 2026', en: 'Google review · January 2026' },
    stars: 4,
    body: {
      it: 'Cocktail superbi e gli spritz "d\'autore" da soli valgono il viaggio. Cucina sopraffina, ma in formato cicchetto: arrivate affamati e prendete più cose. Le sere live sono affollate, prenotate. Una piccola gemma trevigiana.',
      en: 'Superb cocktails, the "signature" spritz alone is worth the trip. The kitchen is excellent but cicchetto-sized: come hungry and order plenty. Live nights get busy, book ahead. A little Treviso gem.',
    },
  },
];

// Helper stelle.
const renderStars = (n: number) => '★'.repeat(n) + '☆'.repeat(5 - n);

// FAQ bilingue: risposte brevi alle domande più ricercate (dove, orari, live,
// prenotazioni). Alimentano sia l'accordion visibile sia lo schema FAQPage qui
// sotto, così la risposta mostrata e quella indicizzata da Google coincidono.
type Faq = {
  q: { it: string; en: string };
  a: { it: string; en: string };
  link?: { href: string; label: { it: string; en: string } };
};
const faqs: Faq[] = [
  {
    q: {
      it: 'Dove si trova Biblio e come ci si arriva?',
      en: 'Where is Biblio and how do I get there?',
    },
    a: {
      it: 'Biblio è in Via Armando Diaz 3/A, nel centro storico di Treviso, a pochi passi da Piazza dei Signori. Diversi parcheggi pubblici sono nelle vicinanze e dalla stazione sono circa 10 minuti a piedi.',
      en: 'Biblio is at Via Armando Diaz 3/A, in the historic centre of Treviso, a few steps from Piazza dei Signori. Several public car parks are nearby and it is about a 10-minute walk from the train station.',
    },
  },
  {
    q: {
      it: 'Quali sono gli orari di apertura?',
      en: 'What are your opening hours?',
    },
    a: {
      it: 'Siamo aperti dal martedì alla domenica dalle 18:00 fino a tardi: l’una di notte, le due il venerdì e il sabato. Il lunedì siamo chiusi.',
      en: 'We are open Tuesday to Sunday from 6:00 PM until late: 1 AM, and 2 AM on Friday and Saturday. We are closed on Mondays.',
    },
  },
  {
    q: {
      it: 'È necessario prenotare un tavolo?',
      en: 'Do I need to book a table?',
    },
    a: {
      it: 'Non è obbligatorio, ma nelle sere con musica dal vivo lo consigliamo: i posti vicino al palco vanno in fretta. Puoi prenotare online, per telefono o su WhatsApp e ti rispondiamo in poche ore.',
      en: 'It is not required, but on live-music nights we recommend it: seats near the stage fill up fast. You can book online, by phone or on WhatsApp, and we reply within a few hours.',
    },
    link: { href: routeMap.prenota[lang], label: { it: 'Prenota un tavolo', en: 'Book a table' } },
  },
  {
    q: {
      it: 'C’è musica dal vivo? In quali serate?',
      en: 'Is there live music? Which nights?',
    },
    a: {
      it: 'Sì, tre sere a settimana e sempre a ingresso libero: il giovedì è dedicato al jazz, il venerdì al blues e al soul, la domenica ai cantautori emergenti. Il programma aggiornato è nella pagina Eventi.',
      en: 'Yes, three nights a week and always free entry: Thursday is jazz, Friday is blues and soul, Sunday is for emerging songwriters. The up-to-date line-up is on the Events page.',
    },
    link: { href: routeMap.eventi[lang], label: { it: 'Scopri gli eventi', en: 'See the events' } },
  },
  {
    q: {
      it: 'Cosa si può mangiare e bere?',
      en: 'What can I eat and drink?',
    },
    a: {
      it: 'Drink d’autore, una lista curata di gin e cocktail, vini del territorio e birre artigianali alla spina, accompagnati da cicchetti gourmet. Il menù completo, food e drink, è sempre online.',
      en: 'Signature drinks, a curated gin and cocktail list, regional wines and craft beers on tap, paired with gourmet cicchetti. The full food and drink menu is always online.',
    },
    link: { href: routeMap.menu[lang], label: { it: 'Sfoglia il menù', en: 'Browse the menu' } },
  },
  {
    q: {
      it: 'Ci sono eventi all’aperto d’estate?',
      en: 'Are there outdoor events in summer?',
    },
    a: {
      it: 'In estate Biblio esce all’aperto con il Biblio Truck ai Giardini di Sant’Andrea, lungo il Sile: concerti al tramonto a ingresso libero, con la stessa cucina e gli stessi drink. Trovi tutto nella pagina del Truck.',
      en: 'In summer Biblio moves outdoors with the Biblio Truck at the Giardini di Sant’Andrea, along the river Sile: free open-air sunset concerts, with the same kitchen and drinks. It is all on the Truck page.',
    },
    link: { href: routeMap.truck[lang], label: { it: 'Scopri il Truck', en: 'Discover the Truck' } },
  },
];

// Schema FAQPage: stessa fonte dell'accordion, così il testo indicizzato
// coincide con quello mostrato. I link interni sono UI a parte (fuori dalla
// risposta), per non divergere dal testo dichiarato a Google.
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q[lang],
    acceptedAnswer: { '@type': 'Answer', text: f.a[lang] },
  })),
};
---

<section class="contatti-page">
  <header class="contatti-hero container">
    <span class="eyebrow">{t(lang, 'hero.tagline')}</span>
    <h1>{t(lang, 'contatti.title')}</h1>
    <p class="lede">{t(lang, 'contatti.lede')}</p>
  </header>

  {/* Info + mappa */}
  <section class="contatti-main bg-paper-2">
    <div class="container">
      <div class="contatti-grid">
        {/* Colonna info */}
        <div class="contatti-info">
          <div class="info-block">
            <h3 class="info-label">{t(lang, 'contatti.phone.label')}</h3>
            <ContactActions lang={lang} />
          </div>

          <div class="info-block">
            <h3 class="info-label">{t(lang, 'contatti.address.label')}</h3>
            <p class="info-body">
              {t(lang, 'contatti.address.body').split('\n').map((line, i) => (
                <>
                  {i > 0 && <br />}
                  {line}
                </>
              ))}
            </p>
            <a class="info-link" href={mapsLinkUrl} target="_blank" rel="noopener noreferrer">
              {t(lang, 'contatti.address.cta')} →
            </a>
          </div>

          <div class="info-block">
            <h3 class="info-label">{t(lang, 'contatti.hours.label')}</h3>
            <p class="info-body info-hours">
              {t(lang, 'contatti.hours.body').split('\n').map((line, i) => (
                <>
                  {i > 0 && <br />}
                  {line}
                </>
              ))}
            </p>
            <p class="info-note">{t(lang, 'contatti.hours.note')}</p>
          </div>

          <div class="info-block">
            <h3 class="info-label">{t(lang, 'contatti.email.label')}</h3>
            <p class="info-body">
              <a class="info-link" href={`mailto:${EMAIL}`}>{EMAIL}</a>
            </p>
          </div>

          <div class="info-block">
            <h3 class="info-label">{t(lang, 'contatti.social.label')}</h3>
            <ul class="social-row" role="list">
              <li>
                <a class="social-link" href={IG_URL} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                  <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2 0 1.9.2 2.4.4.6.2 1 .5 1.5 1s.8.9 1 1.5c.2.5.4 1.2.4 2.4.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c0 1.2-.2 1.9-.4 2.4a4 4 0 0 1-1 1.5c-.5.5-.9.8-1.5 1-.5.2-1.2.4-2.4.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2 0-1.9-.2-2.4-.4a4 4 0 0 1-1.5-1 4 4 0 0 1-1-1.5c-.2-.5-.4-1.2-.4-2.4C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c0-1.2.2-1.9.4-2.4.2-.6.5-1 1-1.5s.9-.8 1.5-1c.5-.2 1.2-.4 2.4-.4C8.4 2.2 8.8 2.2 12 2.2Zm0 1.8c-3.2 0-3.5 0-4.7.1-1.1.1-1.7.2-2.1.4-.5.2-.9.4-1.3.8-.4.4-.6.8-.8 1.3-.2.4-.3 1-.4 2.1-.1 1.2-.1 1.5-.1 4.7s0 3.5.1 4.7c.1 1.1.2 1.7.4 2.1.2.5.4.9.8 1.3.4.4.8.6 1.3.8.4.2 1 .3 2.1.4 1.2.1 1.5.1 4.7.1s3.5 0 4.7-.1c1.1-.1 1.7-.2 2.1-.4.5-.2.9-.4 1.3-.8.4-.4.6-.8.8-1.3.2-.4.3-1 .4-2.1.1-1.2.1-1.5.1-4.7s0-3.5-.1-4.7c-.1-1.1-.2-1.7-.4-2.1a3 3 0 0 0-.8-1.3 3 3 0 0 0-1.3-.8c-.4-.2-1-.3-2.1-.4-1.2-.1-1.5-.1-4.7-.1Zm0 3a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.8a3.2 3.2 0 1 0 0 6.4 3.2 3.2 0 0 0 0-6.4Zm5.4-2a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4Z"/></svg>
                  <span>Instagram</span>
                </a>
              </li>
              <li>
                <a class="social-link" href={FB_URL} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                  <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M22 12a10 10 0 1 0-11.6 9.9V14.9H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5H15c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.5 2.9h-2.3v7A10 10 0 0 0 22 12Z"/></svg>
                  <span>Facebook</span>
                </a>
              </li>
            </ul>
          </div>
        </div>

        {/* Colonna mappa */}
        <div class="contatti-map">
          <h3 class="map-title">{t(lang, 'contatti.map.title')}</h3>
          <div class="map-frame">
            <iframe
              src={mapsEmbedUrl}
              width="100%"
              height="420"
              style="border:0"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Biblio, Via Armando Diaz 3/A, Treviso"
              allowfullscreen
            ></iframe>
          </div>
          <p class="map-note">{t(lang, 'contatti.map.note')}</p>
        </div>
      </div>
    </div>
  </section>

  {/* Recensioni */}
  <section class="contatti-reviews">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{t(lang, 'contatti.reviews.title')}</span>
        <h2>{t(lang, 'contatti.reviews.title')}</h2>
        <p>{t(lang, 'contatti.reviews.intro')}</p>
      </div>

      <ul class="reviews-grid" role="list">
        {reviews.map((r, i) => (
          <li class="review-card reveal" style={`--reveal-delay:${(i % 4) * 0.07}s`}>
            <p class="review-stars" aria-label={`${r.stars} ${t(lang, 'contatti.reviews.stars.label')}`}>
              {renderStars(r.stars)}
            </p>
            <blockquote class="review-body">
              <p>{r.body[lang]}</p>
            </blockquote>
            <p class="review-author">
              <span class="review-name">{r.name}</span>
              <span class="review-meta">{r.meta[lang]}</span>
            </p>
          </li>
        ))}
      </ul>

      <p class="reviews-cta">
        <a href={mapsLinkUrl} target="_blank" rel="noopener noreferrer">
          {t(lang, 'contatti.reviews.cta')} →
        </a>
      </p>
    </div>
  </section>

  {/* FAQ — risposte brevi + schema FAQPage */}
  <section class="contatti-faq bg-paper-2">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">{t(lang, 'contatti.faq.eyebrow')}</span>
        <h2>{t(lang, 'contatti.faq.title')}</h2>
        <p>{t(lang, 'contatti.faq.intro')}</p>
      </div>

      <ul class="faq-list" role="list">
        {faqs.map((f, i) => (
          <li class="faq-item reveal" style={`--reveal-delay:${(i % 3) * 0.06}s`}>
            <details class="faq-details">
              <summary class="faq-summary">
                <span class="faq-q">{f.q[lang]}</span>
                <span class="faq-icon" aria-hidden="true"></span>
              </summary>
              <div class="faq-a">
                <p>{f.a[lang]}</p>
                {f.link && (
                  <a class="faq-link" href={f.link.href}>{f.link.label[lang]} →</a>
                )}
              </div>
            </details>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* CTA finale */}
  <section class="cta-banner">
    <span class="eyebrow">{t(lang, 'contatti.cta.title')}</span>
    <h2>{t(lang, 'contatti.cta.title')}</h2>
    <p>{t(lang, 'contatti.cta.body')}</p>
    <a class="btn" href={routeMap.prenota[lang]}>{t(lang, 'contatti.cta.btn')}</a>
  </section>

  {/* Dati strutturati: FAQ in formato FAQPage, così Google può mostrare le
      risposte direttamente nei risultati di ricerca. */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />
</section>

<!-- Scroll-reveal è gestito globalmente dal Base layout. -->

<style>
  .contatti-faq {
    padding-block: clamp(3rem, 7vw, 5.5rem);
  }

  .faq-list {
    list-style: none;
    margin: 2.5rem auto 0;
    padding: 0;
    max-width: 56rem;
    display: grid;
    gap: 0.75rem;
  }

  .faq-details {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }
  .faq-details[open] {
    border-color: var(--brass);
    box-shadow: var(--shadow-soft);
  }

  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 1.4rem;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.3;
    color: var(--ink);
  }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary:hover .faq-q { color: var(--brass-deep); }
  .faq-q { transition: color 0.2s var(--ease); }

  /* Icona +/× che ruota all'apertura. */
  .faq-icon {
    position: relative;
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    transition: transform 0.3s var(--ease);
  }
  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    background: var(--brass);
    border-radius: 2px;
  }
  .faq-icon::before { inset: 8px 0; height: 2px; }
  .faq-icon::after { inset: 0 8px; width: 2px; }
  .faq-details[open] .faq-icon { transform: rotate(135deg); }

  .faq-a {
    padding: 0 1.4rem 1.3rem;
    color: var(--ink-soft);
  }
  .faq-a p {
    margin: 0;
    line-height: 1.7;
  }

  .faq-link {
    display: inline-block;
    margin-top: 0.85rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--brass-deep);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--brass) 45%, transparent);
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  .faq-link:hover {
    color: var(--ink);
    border-bottom-color: var(--brass);
  }

  @media (max-width: 640px) {
    .faq-summary { font-size: 1.15rem; padding: 1rem 1.1rem; }
    .faq-a { padding: 0 1.1rem 1.1rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-details,
    .faq-icon,
    .faq-q,
    .faq-link { transition: none; }
  }
</style>

