---
import logoSvg from '../assets/img/logo/logo.svg?raw';
import { type Lang, t, routeMap } from '../i18n/ui';

interface Props {
  lang: Lang;
  currentRoute: 'home' | 'truck' | 'menu' | 'eventi' | 'prenota' | 'contatti' | 'artisti';
}

const { lang, currentRoute } = Astro.props;
const items = ['home', 'truck', 'menu', 'eventi', 'prenota', 'contatti', 'artisti'] as const;

const itHref = routeMap[currentRoute].it;
const enHref = routeMap[currentRoute].en;
---

<nav class="nav" aria-label="Primary">
  <div class="container nav-inner">
    <a class="brand" href={routeMap.home[lang]} aria-label="Biblio, home">
      <span class="brand-logo" set:html={logoSvg}></span>
    </a>

    <button class="nav-toggle" aria-expanded="false" aria-controls="primary-nav" aria-label={t(lang, 'nav.menu.toggle')}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>

    <ul class="nav-links" id="primary-nav">
      {items.map((item) => {
        const href = routeMap[item][lang];
        const labelKey = `nav.${item === 'home' ? 'home' : item}` as const;
        return (
          <li>
            <a href={href} class={currentRoute === item ? 'is-active' : ''}>
              {t(lang, labelKey)}
            </a>
          </li>
        );
      })}
      <li class="lang-switch" aria-label="Language">
        <a href={itHref} class={lang === 'it' ? 'is-active' : ''} hreflang="it" aria-label="Italiano">
          <svg class="flag" viewBox="0 0 3 2" aria-hidden="true">
            <rect width="1" height="2" x="0" fill="#0e7c3a"/>
            <rect width="1" height="2" x="1" fill="#f6efe1"/>
            <rect width="1" height="2" x="2" fill="#c8312b"/>
          </svg>
          IT
        </a>
        <a href={enHref} class={lang === 'en' ? 'is-active' : ''} hreflang="en" aria-label="English">
          <svg class="flag" viewBox="0 0 60 30" aria-hidden="true">
            <clipPath id="t"><path d="M30,15 h30 v15 z v15 h-30 z h-30 v-15 z v-15 h30 z"/></clipPath>
            <path d="M0,0 v30 h60 v-30 z" fill="#012169"/>
            <path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/>
            <path d="M0,0 L60,30 M60,0 L0,30" clip-path="url(#t)" stroke="#C8102E" stroke-width="4"/>
            <path d="M30,0 v30 M0,15 h60" stroke="#fff" stroke-width="10"/>
            <path d="M30,0 v30 M0,15 h60" stroke="#C8102E" stroke-width="6"/>
          </svg>
          EN
        </a>
      </li>
    </ul>
  </div>
</nav>
