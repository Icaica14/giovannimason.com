---
// Bottoni Telefono + WhatsApp del locale, riusabili (pagina Contatti, dettaglio
// evento, …). Unico punto in cui vivono il numero e l'URL WhatsApp: cambiare qui
// li aggiorna ovunque. Gli stili (.info-actions / .info-action*) sono globali.
import { type Lang, t } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Numero ufficiale del locale (dalla locandina).
const TEL_NUMBER  = '+390422270575';
const TEL_DISPLAY = '+39 0422 270 575';

// WhatsApp con messaggio precompilato bilingue (chiave condivisa con i form).
const waPrefill = t(lang, 'prenota.wa.prefill');
const waUrl = `https://wa.me/${TEL_NUMBER.replace(/\D/g, '')}?text=${encodeURIComponent(waPrefill)}`;
---

<ul class="info-actions" role="list">
  <li>
    <a class="info-action" href={`tel:${TEL_NUMBER}`}>
      <span class="info-action-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M6.6 10.8a15.1 15.1 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.2 11.4 11.4 0 0 0 3.6.6 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .6 3.6 1 1 0 0 1-.2 1Z"/></svg>
      </span>
      {TEL_DISPLAY}
    </a>
  </li>
  <li>
    <a class="info-action info-action-wa" href={waUrl} target="_blank" rel="noopener noreferrer">
      <span class="info-action-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M20 3.5A11.4 11.4 0 0 0 12 .2 11.7 11.7 0 0 0 1.6 17.7L0 24l6.5-1.7A11.7 11.7 0 0 0 23.7 12 11.4 11.4 0 0 0 20 3.5Zm-8 18.4a9.7 9.7 0 0 1-4.9-1.3l-.4-.2-3.9 1 1-3.8-.2-.4A9.7 9.7 0 1 1 21.7 12 9.7 9.7 0 0 1 12 21.9Zm5.3-7.3c-.3-.1-1.7-.8-2-.9s-.5-.1-.7.1-.8.9-1 1.1-.4.2-.7.1a8 8 0 0 1-2.4-1.5 9 9 0 0 1-1.6-2c-.2-.3 0-.5.1-.7l.5-.5a2 2 0 0 0 .3-.5.5.5 0 0 0 0-.5l-.9-2c-.2-.6-.4-.5-.6-.5h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-.9 2.2 5.1 5.1 0 0 0 1.1 2.7 11.7 11.7 0 0 0 4.5 4 15 15 0 0 0 1.5.5 3.6 3.6 0 0 0 1.6.1 2.7 2.7 0 0 0 1.7-1.2 2.1 2.1 0 0 0 .2-1.2c-.1-.1-.3-.2-.5-.3Z"/></svg>
      </span>
      WhatsApp
    </a>
  </li>
</ul>
