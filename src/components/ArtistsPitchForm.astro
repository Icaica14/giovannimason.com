---
import { type Lang, t, routeMap } from '../i18n/ui';
import logoSvg from '../assets/img/logo/logo.svg?raw';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Invio tramite Edge Function Supabase `submit-application` (Turnstile +
// validazione + insert + URL di upload firmati per il bucket privato + email).
// I file vengono caricati dal client direttamente sullo storage usando i token
// firmati restituiti dalla function. Anon key e URL sono pubblici per design.
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL as string | undefined;
const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string | undefined;
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY as string | undefined;
const submitEndpoint = SUPABASE_URL ? `${SUPABASE_URL}/functions/v1/submit-application` : '';
---

<section class="artisti-page">
  <header class="artisti-hero container">
    <span class="eyebrow">{t(lang, 'artisti.tagline')}</span>
    <h1>{t(lang, 'artisti.title')}</h1>
    <p class="lede">{t(lang, 'artisti.lede')}</p>
  </header>

  {/* Form vero e proprio, sezioni multiple */}
  <section class="artisti-form-wrap bg-paper-2">
    <div class="container">
      <form
        class="artisti-form"
        id="artistiForm"
        action={submitEndpoint}
        data-endpoint={submitEndpoint}
        data-supabase-url={SUPABASE_URL ?? ''}
        data-supabase-key={SUPABASE_ANON_KEY ?? ''}
        method="POST"
        novalidate
      >
        {/* Honeypot anti-spam */}
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="display:none" />
        <input type="hidden" name="lang" value={lang} />

        {/* SEZIONE 1: chi siete */}
        <fieldset class="form-section">
          <legend class="form-section-title">{t(lang, 'artisti.form.section.who')}</legend>
          <div class="form-grid">
            <label class="field field-full">
              <span class="field-label">
                {t(lang, 'artisti.form.artist.name')} <em class="req" aria-hidden="true">*</em>
              </span>
              <input
                type="text"
                name="artist_name"
                required
                placeholder={t(lang, 'artisti.form.artist.placeholder')}
              />
            </label>

            <label class="field">
              <span class="field-label">
                {t(lang, 'artisti.form.contact.name')} <em class="req" aria-hidden="true">*</em>
              </span>
              <input
                type="text"
                name="contact_name"
                required
                autocomplete="name"
                placeholder={t(lang, 'artisti.form.contact.placeholder')}
              />
            </label>

            <label class="field">
              <span class="field-label">
                {t(lang, 'artisti.form.email')} <em class="req" aria-hidden="true">*</em>
              </span>
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                inputmode="email"
                placeholder="email@example.com"
              />
            </label>

            <label class="field">
              <span class="field-label">
                {t(lang, 'artisti.form.phone')} <span class="opt">{t(lang, 'artisti.form.optional')}</span>
              </span>
              <input
                type="tel"
                name="phone"
                autocomplete="tel"
                inputmode="tel"
                placeholder="+39 …"
              />
            </label>

            <label class="field">
              <span class="field-label">
                {t(lang, 'artisti.form.city')} <span class="opt">{t(lang, 'artisti.form.optional')}</span>
              </span>
              <input
                type="text"
                name="city"
                placeholder={t(lang, 'artisti.form.city.placeholder')}
              />
            </label>
          </div>
        </fieldset>

        {/* SEZIONE 2: la proposta artistica */}
        <fieldset class="form-section">
          <legend class="form-section-title">{t(lang, 'artisti.form.section.act')}</legend>
          <div class="form-grid">
            <label class="field">
              <span class="field-label">
                {t(lang, 'artisti.form.lineup')} <em class="req" aria-hidden="true">*</em>
              </span>
              <select name="lineup" required>
                <option value="">…</option>
                <option value="solo">{t(lang, 'artisti.form.lineup.solo')}</option>
                <option value="duo">{t(lang, 'artisti.form.lineup.duo')}</option>
                <option value="trio">{t(lang, 'artisti.form.lineup.trio')}</option>
                <option value="band">{t(lang, 'artisti.form.lineup.band')}</option>
              </select>
            </label>

            <label class="field">
              <span class="field-label">
                {t(lang, 'artisti.form.genre')} <em class="req" aria-hidden="true">*</em>
              </span>
              <select name="genre" id="genreSelect" required>
                <option value="">…</option>
                <option value="jazz">{t(lang, 'artisti.form.genre.jazz')}</option>
                <option value="blues">{t(lang, 'artisti.form.genre.blues')}</option>
                <option value="soul">{t(lang, 'artisti.form.genre.soul')}</option>
                <option value="songwriter">{t(lang, 'artisti.form.genre.songwriter')}</option>
                <option value="indie">{t(lang, 'artisti.form.genre.indie')}</option>
                <option value="classical">{t(lang, 'artisti.form.genre.classical')}</option>
                <option value="other">{t(lang, 'artisti.form.genre.other')}</option>
              </select>
            </label>

            {/* Campo libero, visibile solo quando si sceglie "Altro" */}
            <label class="field" id="genreOtherField" hidden>
              <span class="field-label">
                {t(lang, 'artisti.form.genre.other.label')} <em class="req" aria-hidden="true">*</em>
              </span>
              <input
                type="text"
                name="genre_other"
                id="genreOtherInput"
                placeholder={t(lang, 'artisti.form.genre.other.placeholder')}
              />
            </label>

            <label class="field">
              <span class="field-label">
                {t(lang, 'artisti.form.repertoire')} <em class="req" aria-hidden="true">*</em>
              </span>
              <select name="repertoire" required>
                <option value="">…</option>
                <option value="original">{t(lang, 'artisti.form.repertoire.original')}</option>
                <option value="cover">{t(lang, 'artisti.form.repertoire.cover')}</option>
                <option value="mixed">{t(lang, 'artisti.form.repertoire.mixed')}</option>
              </select>
            </label>

            <label class="field field-full">
              <span class="field-label">
                {t(lang, 'artisti.form.bio')} <span class="opt">{t(lang, 'artisti.form.optional')}</span>
              </span>
              <textarea
                name="bio"
                rows="4"
                maxlength="600"
                placeholder={t(lang, 'artisti.form.bio.placeholder')}
              ></textarea>
            </label>
          </div>
        </fieldset>

        {/* SEZIONE 3: materiali */}
        <fieldset class="form-section">
          <legend class="form-section-title">{t(lang, 'artisti.form.section.media')}</legend>
          <div class="form-grid">
            <label class="field field-full">
              <span class="field-label">
                {t(lang, 'artisti.form.link1')} <em class="req" aria-hidden="true">*</em>
              </span>
              <input
                type="url"
                name="link1"
                required
                inputmode="url"
                placeholder={t(lang, 'artisti.form.link1.placeholder')}
              />
            </label>

            <label class="field field-full">
              <span class="field-label">
                {t(lang, 'artisti.form.link2')} <span class="opt">{t(lang, 'artisti.form.optional')}</span>
              </span>
              <input
                type="url"
                name="link2"
                inputmode="url"
                placeholder="https://"
              />
            </label>

            <label class="field field-full">
              <span class="field-label">
                {t(lang, 'artisti.form.link3')} <span class="opt">{t(lang, 'artisti.form.optional')}</span>
              </span>
              <input
                type="url"
                name="link3"
                inputmode="url"
                placeholder="https://"
              />
            </label>

            <label class="field field-full">
              <span class="field-label">
                {t(lang, 'artisti.form.epk')} <span class="opt">{t(lang, 'artisti.form.optional')}</span>
              </span>
              <input
                type="url"
                name="epk"
                inputmode="url"
                placeholder={t(lang, 'artisti.form.epk.placeholder')}
              />
            </label>

            <label class="field field-full">
              <span class="field-label">
                {t(lang, 'artisti.form.experience')} <span class="opt">{t(lang, 'artisti.form.optional')}</span>
              </span>
              <textarea
                name="experience"
                rows="3"
                placeholder={t(lang, 'artisti.form.experience.placeholder')}
              ></textarea>
            </label>

            {/* Upload file: audio/foto/PDF verso il bucket privato (max 5, 20MB l'uno) */}
            <label class="field field-full">
              <span class="field-label">
                {t(lang, 'artisti.form.files')} <span class="opt">{t(lang, 'artisti.form.optional')}</span>
              </span>
              <input
                type="file"
                name="files"
                id="artistiFiles"
                multiple
                accept=".jpg,.jpeg,.png,.webp,.pdf,.mp3,.m4a,.wav,image/jpeg,image/png,image/webp,application/pdf,audio/mpeg,audio/mp4,audio/wav"
              />
              <small class="field-hint">{t(lang, 'artisti.form.files.hint')}</small>
              <ul class="file-list" id="artistiFileList" role="list"></ul>
              <p class="form-error" id="artistiFileError" hidden role="alert"></p>
            </label>
          </div>
        </fieldset>

        {/* SEZIONE 4: logistica */}
        <fieldset class="form-section">
          <legend class="form-section-title">{t(lang, 'artisti.form.section.logistics')}</legend>
          <div class="form-grid">
            <label class="field field-full">
              <span class="field-label">
                {t(lang, 'artisti.form.availability')} <span class="opt">{t(lang, 'artisti.form.optional')}</span>
              </span>
              <textarea
                name="availability"
                rows="2"
                placeholder={t(lang, 'artisti.form.availability.placeholder')}
              ></textarea>
            </label>

            <label class="field">
              <span class="field-label">
                {t(lang, 'artisti.form.fee')} <span class="opt">{t(lang, 'artisti.form.optional')}</span>
              </span>
              <input
                type="text"
                name="fee"
                placeholder={t(lang, 'artisti.form.fee.placeholder')}
              />
            </label>

            <label class="field field-full">
              <span class="field-label">
                {t(lang, 'artisti.form.note')} <span class="opt">{t(lang, 'artisti.form.optional')}</span>
              </span>
              <textarea
                name="note"
                rows="3"
                placeholder={t(lang, 'artisti.form.note.placeholder')}
              ></textarea>
            </label>
          </div>
        </fieldset>

        <p class="form-privacy">{t(lang, 'artisti.form.privacy')}</p>

        {/* Widget anti-spam Cloudflare Turnstile (reso solo se configurato) */}
        {TURNSTILE_SITE_KEY && (
          <div
            class="cf-turnstile artisti-turnstile"
            data-sitekey={TURNSTILE_SITE_KEY}
            data-theme="light"
          ></div>
        )}

        <div class="form-actions">
          <button type="submit" class="btn btn-primary" id="artistiSubmit">
            {t(lang, 'artisti.form.submit')}
          </button>
        </div>

        <div class="form-success" id="artistiSuccess" hidden>
          <h3>{t(lang, 'artisti.success.title')}</h3>
          <p>{t(lang, 'artisti.success.body')}</p>
        </div>
        <p class="form-error" id="artistiError" hidden role="alert">
          {t(lang, 'artisti.error')}
        </p>
      </form>
    </div>
  </section>

  {/* CTA finale: vieni a vedere il locale */}
  <section class="cta-banner">
    <span class="eyebrow">{t(lang, 'artisti.cta.title')}</span>
    <h2>{t(lang, 'artisti.cta.title')}</h2>
    <p>{t(lang, 'artisti.cta.body')}</p>
    <a class="btn" href={routeMap.eventi[lang]}>{t(lang, 'artisti.cta.btn')}</a>
  </section>

  {/* Pop-up "campi obbligatori": rettangolo con logo Biblio + messaggio. */}
  <div class="req-modal" id="reqModal" hidden>
    <div class="req-modal-backdrop" data-modal-close></div>
    <div class="req-modal-card" role="alertdialog" aria-modal="true" aria-labelledby="reqModalText">
      <span class="req-modal-logo" aria-hidden="true" set:html={logoSvg}></span>
      <p class="req-modal-text" id="reqModalText">{t(lang, 'artisti.form.required.popup')}</p>
      <button type="button" class="btn btn-primary req-modal-ok" data-modal-close>OK</button>
    </div>
  </div>
</section>

<style>
  /* Pop-up "campi obbligatori": rettangolo centrato con logo Biblio e messaggio. */
  .req-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: grid;
    place-items: center;
    padding: 1.5rem;
  }
  .req-modal[hidden] {
    display: none;
  }
  .req-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(20, 12, 6, 0.55);
    backdrop-filter: blur(3px);
  }
  .req-modal-card {
    position: relative;
    width: 100%;
    max-width: 25rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 2.2rem 2rem 2rem;
    text-align: center;
    box-shadow: 0 24px 70px -24px rgba(0, 0, 0, 0.55);
    animation: reqPop 0.22s var(--ease);
  }
  @keyframes reqPop {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  /* Logo Biblio: emblema rosso + wordmark in colore scuro (su carta chiara). */
  .req-modal-logo {
    display: block;
    color: var(--logo-red);
    --logo-ink: var(--ink);
    line-height: 0;
  }
  .req-modal-logo :global(svg) {
    width: clamp(110px, 42%, 150px);
    height: auto;
    margin: 0 auto;
    display: block;
  }
  .req-modal-text {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3.6vw, 1.55rem);
    line-height: 1.25;
    color: var(--ink);
    margin: 1.1rem auto 1.5rem;
    max-width: 22ch;
  }
  .req-modal-ok {
    min-width: 8rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .req-modal-card {
      animation: none;
    }
  }
</style>

{/* Script Turnstile: caricato solo se la site key è configurata. */}
{TURNSTILE_SITE_KEY && (
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<script>
  const form = document.getElementById('artistiForm') as HTMLFormElement | null;
  const submitBtn = document.getElementById('artistiSubmit') as HTMLButtonElement | null;
  const successEl = document.getElementById('artistiSuccess') as HTMLElement | null;
  const errorEl = document.getElementById('artistiError') as HTMLElement | null;

  // Lingua corrente, per i messaggi lato client.
  const lang = (form?.querySelector('input[name="lang"]') as HTMLInputElement | null)?.value === 'en' ? 'en' : 'it';
  const M = {
    tooMany: lang === 'en' ? 'Up to 5 files.' : 'Massimo 5 file.',
    tooBig: lang === 'en' ? 'Each file must be ≤ 20MB.' : 'Ogni file deve essere ≤ 20MB.',
    badType: lang === 'en' ? 'Unsupported format.' : 'Formato non supportato.',
    uploading: lang === 'en' ? 'Uploading your files…' : 'Caricamento dei file in corso…',
  };

  // ── Genere "Altro": mostra/nasconde il campo libero ──────────────────────
  const genreSelect = document.getElementById('genreSelect') as HTMLSelectElement | null;
  const genreOtherField = document.getElementById('genreOtherField') as HTMLElement | null;
  const genreOtherInput = document.getElementById('genreOtherInput') as HTMLInputElement | null;
  const syncGenreOther = () => {
    const isOther = genreSelect?.value === 'other';
    if (genreOtherField) genreOtherField.hidden = !isOther;
    if (genreOtherInput) {
      genreOtherInput.required = !!isOther;
      if (!isOther) genreOtherInput.value = '';
    }
  };
  genreSelect?.addEventListener('change', syncGenreOther);
  syncGenreOther();

  // ── Pop-up "campi obbligatori" ───────────────────────────────────────────
  // Campi obbligatori del form (in ordine): nome d'arte/band, contatto, email,
  // formazione, genere (+ "Altro"), repertorio, primo link audio/video.
  const reqModal = document.getElementById('reqModal') as HTMLElement | null;
  const REQUIRED_FIELDS = ['artist_name', 'contact_name', 'email', 'lineup', 'genre', 'repertoire', 'link1'];
  let reqRefocus: HTMLElement | null = null;

  const openReqModal = (focusTarget: HTMLElement | null) => {
    if (!reqModal) return;
    reqRefocus = focusTarget;
    reqModal.hidden = false;
    (reqModal.querySelector('.req-modal-ok') as HTMLElement | null)?.focus();
  };
  const closeReqModal = () => {
    if (!reqModal || reqModal.hidden) return;
    reqModal.hidden = true;
    reqRefocus?.focus();
    reqRefocus = null;
  };
  reqModal?.querySelectorAll('[data-modal-close]').forEach((el) => el.addEventListener('click', closeReqModal));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeReqModal();
  });

  /** Primo campo obbligatorio mancante o non valido; null se sono tutti a posto. */
  const firstMissingRequired = (): HTMLElement | null => {
    for (const name of REQUIRED_FIELDS) {
      const el = form?.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement | null;
      if (!el) continue;
      if (!el.value.trim() || !el.checkValidity()) return el;
    }
    if (genreSelect?.value === 'other' && genreOtherInput && !genreOtherInput.value.trim()) {
      return genreOtherInput;
    }
    return null;
  };

  // ── Validazione file lato client ─────────────────────────────────────────
  const MAX_FILES = 5;
  const MAX_BYTES = 20 * 1024 * 1024;
  const ALLOWED_EXT = /\.(jpe?g|png|webp|pdf|mp3|m4a|wav)$/i;
  const fileInput = document.getElementById('artistiFiles') as HTMLInputElement | null;
  const fileList = document.getElementById('artistiFileList') as HTMLUListElement | null;
  const fileError = document.getElementById('artistiFileError') as HTMLElement | null;

  const fmtSize = (b: number) => (b < 1024 * 1024 ? `${Math.round(b / 1024)} KB` : `${(b / 1024 / 1024).toFixed(1)} MB`);

  const validateFiles = (): File[] => {
    const files = Array.from(fileInput?.files ?? []);
    if (fileError) {
      fileError.hidden = true;
      fileError.textContent = '';
    }
    if (fileList) fileList.innerHTML = '';
    let err = '';
    if (files.length > MAX_FILES) err = M.tooMany;
    for (const f of files) {
      if (!ALLOWED_EXT.test(f.name)) err = M.badType;
      else if (f.size > MAX_BYTES) err = M.tooBig;
      if (fileList) {
        const li = document.createElement('li');
        li.textContent = `${f.name} — ${fmtSize(f.size)}`;
        fileList.appendChild(li);
      }
    }
    if (err && fileError) {
      fileError.textContent = err;
      fileError.hidden = false;
    }
    return files;
  };
  fileInput?.addEventListener('change', validateFiles);

  // ── Carica i file direttamente sullo storage via signed upload URL ───────
  type Upload = { path: string; token: string };
  async function uploadFiles(uploads: Upload[], files: File[]) {
    if (!uploads.length) return;
    const url = form?.dataset.supabaseUrl;
    const key = form?.dataset.supabaseKey;
    if (!url || !key) return;
    const { createClient } = await import('@supabase/supabase-js');
    const sb = createClient(url, key);
    for (let i = 0; i < uploads.length; i++) {
      const up = uploads[i];
      const file = files[i];
      if (!up?.token || !file) continue; // URL firmato fallito → salta
      const { error } = await sb.storage
        .from('applications')
        .uploadToSignedUrl(up.path, up.token, file, { contentType: file.type || undefined });
      if (error) throw error;
    }
  }

  // ── Submit ───────────────────────────────────────────────────────────────
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const endpoint = form.dataset.endpoint;
    if (!endpoint) {
      errorEl?.removeAttribute('hidden');
      return;
    }

    // Campi obbligatori mancanti → pop-up con logo Biblio, niente invio.
    const missing = firstMissingRequired();
    if (missing) {
      openReqModal(missing);
      return;
    }

    const files = validateFiles();
    if (fileError && !fileError.hidden) return; // errori file → blocca

    submitBtn?.setAttribute('disabled', 'true');
    errorEl?.setAttribute('hidden', '');

    const fd = new FormData(form);
    const tokenEl = form.querySelector('[name="cf-turnstile-response"]') as HTMLTextAreaElement | null;
    const payload = {
      artist_name: String(fd.get('artist_name') ?? ''),
      contact_name: String(fd.get('contact_name') ?? ''),
      email: String(fd.get('email') ?? ''),
      phone: String(fd.get('phone') ?? ''),
      city: String(fd.get('city') ?? ''),
      lineup: String(fd.get('lineup') ?? ''),
      genre: String(fd.get('genre') ?? ''),
      genre_other: String(fd.get('genre_other') ?? ''),
      repertoire: String(fd.get('repertoire') ?? ''),
      bio: String(fd.get('bio') ?? ''),
      link1: String(fd.get('link1') ?? ''),
      link2: String(fd.get('link2') ?? ''),
      link3: String(fd.get('link3') ?? ''),
      epk: String(fd.get('epk') ?? ''),
      experience: String(fd.get('experience') ?? ''),
      availability: String(fd.get('availability') ?? ''),
      fee: String(fd.get('fee') ?? ''),
      note: String(fd.get('note') ?? ''),
      lang,
      _gotcha: String(fd.get('_gotcha') ?? ''),
      turnstileToken: tokenEl?.value ?? '',
      files: files.map((f) => ({ name: f.name, size: f.size, type: f.type })),
    };

    try {
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(payload),
      });
      const out = (await res.json().catch(() => ({}))) as { ok?: boolean; uploads?: Upload[] };
      if (res.ok && out.ok) {
        if (out.uploads?.length) {
          if (submitBtn) submitBtn.textContent = M.uploading;
          await uploadFiles(out.uploads, files);
        }
        form.hidden = true;
        successEl?.removeAttribute('hidden');
      } else {
        errorEl?.removeAttribute('hidden');
        submitBtn?.removeAttribute('disabled');
        (window as unknown as { turnstile?: { reset?: () => void } }).turnstile?.reset?.();
      }
    } catch {
      errorEl?.removeAttribute('hidden');
      submitBtn?.removeAttribute('disabled');
      (window as unknown as { turnstile?: { reset?: () => void } }).turnstile?.reset?.();
    }
  });
</script>
