---
import logoSvg from '../assets/img/logo/logo.svg?raw';
import { type Lang, t, routeMap } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const items = ['home', 'menu', 'eventi', 'prenota', 'contatti', 'artisti'] as const;

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a class="brand brand-footer" href={routeMap.home[lang]} aria-label="Biblio, home">
          <span class="brand-logo" set:html={logoSvg}></span>
        </a>
        <p>{t(lang, 'footer.tagline')}</p>
        <p style="margin-top:.6rem; font-style: italic; color: var(--paper-3); max-width: 22rem;">
          {t(lang, 'footer.about')}
        </p>
      </div>

      <div>
        <h4>{t(lang, 'footer.nav.title')}</h4>
        <ul style="list-style:none; padding:0; margin:0; display:grid; gap:.5rem;">
          {items.map((item) => {
            const href = routeMap[item][lang];
            const labelKey = `nav.${item === 'home' ? 'home' : item}` as const;
            return <li><a href={href}>{t(lang, labelKey)}</a></li>;
          })}
        </ul>
      </div>

      <div>
        <h4>{t(lang, 'footer.contatti.title')}</h4>
        <p style="margin:0 0 .5rem;">
          Via Armando Diaz, 3/A<br />
          31100 Treviso (TV)
        </p>
        <p style="margin:0 0 .5rem;">
          <a href="tel:+390422270575">+39 0422 270 575</a>
        </p>
        <p style="margin:0 0 .8rem;">
          <a href="mailto:biblio.bookcafe@gmail.com">biblio.bookcafe@gmail.com</a>
        </p>
        <ul class="footer-social" role="list">
          <li>
            <a class="footer-social-icon" href="https://www.instagram.com/biblio_treviso/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                <path fill="currentColor" d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2 0 1.9.2 2.4.4.6.2 1 .5 1.5 1s.8.9 1 1.5c.2.5.4 1.2.4 2.4.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c0 1.2-.2 1.9-.4 2.4a4 4 0 0 1-1 1.5c-.5.5-.9.8-1.5 1-.5.2-1.2.4-2.4.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2 0-1.9-.2-2.4-.4a4 4 0 0 1-1.5-1 4 4 0 0 1-1-1.5c-.2-.5-.4-1.2-.4-2.4C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c0-1.2.2-1.9.4-2.4.2-.6.5-1 1-1.5s.9-.8 1.5-1c.5-.2 1.2-.4 2.4-.4C8.4 2.2 8.8 2.2 12 2.2Zm0 1.8c-3.2 0-3.5 0-4.7.1-1.1.1-1.7.2-2.1.4-.5.2-.9.4-1.3.8-.4.4-.6.8-.8 1.3-.2.4-.3 1-.4 2.1-.1 1.2-.1 1.5-.1 4.7s0 3.5.1 4.7c.1 1.1.2 1.7.4 2.1.2.5.4.9.8 1.3.4.4.8.6 1.3.8.4.2 1 .3 2.1.4 1.2.1 1.5.1 4.7.1s3.5 0 4.7-.1c1.1-.1 1.7-.2 2.1-.4.5-.2.9-.4 1.3-.8.4-.4.6-.8.8-1.3.2-.4.3-1 .4-2.1.1-1.2.1-1.5.1-4.7s0-3.5-.1-4.7c-.1-1.1-.2-1.7-.4-2.1a3 3 0 0 0-.8-1.3 3 3 0 0 0-1.3-.8c-.4-.2-1-.3-2.1-.4-1.2-.1-1.5-.1-4.7-.1Zm0 3a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.8a3.2 3.2 0 1 0 0 6.4 3.2 3.2 0 0 0 0-6.4Zm5.4-2a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4Z"/>
              </svg>
            </a>
          </li>
          <li>
            <a class="footer-social-icon" href="https://www.facebook.com/p/Biblio-100087459455523/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                <path fill="currentColor" d="M22 12a10 10 0 1 0-11.6 9.9V14.9H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5H15c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.5 2.9h-2.3v7A10 10 0 0 0 22 12Z"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      © {year} {t(lang, 'footer.copyright')}
    </div>
  </div>
</footer>
