---
import { getImage } from 'astro:assets';
import heroSrc from '../assets/img/interni/img_1.webp';
import truckSrc from '../assets/img/truck/bancone.jpg';
import logoSvg from '../assets/img/logo/logo.svg?raw';
import { type Lang, t, routeMap } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Hero-carousel a due viste (slide 1 = bar Biblio, slide 2 = Biblio Truck).
// SCORRIMENTO reale (translateX su un track flex) con LOOP CONTINUO IN AVANTI
// (clone della prima slide in coda) → niente effetto ping-pong. Lo sfondo è una
// CSS background `cover` (riempie sempre la slide, niente fasce su iOS Safari).
const barOpt = await getImage({ src: heroSrc, width: 1600, format: 'webp', quality: 80 });
const truckOpt = await getImage({ src: truckSrc, width: 1600, format: 'webp', quality: 78 });

const truckHref = routeMap.truck[lang];
const eventiHref = routeMap.eventi[lang];
const goto = t(lang, 'hero.carousel.goto');
---

<section class="hero-carousel" aria-roledescription="carousel" aria-label={t(lang, 'hero.carousel.label')}>
  <div class="hero-viewport">
    <div class="hero-track" data-hero-track>
      {/* Slide 1 — Bar Biblio */}
      <article class="hero hero-slide" style={`--hero-bg: url("${barOpt.src}")`} aria-roledescription="slide" aria-label="Biblio">
        <div class="hero-inner">
          <h1 class="hero-logo" set:html={logoSvg} aria-label="Biblio"></h1>
          <p class="lede">{t(lang, 'hero.lede1')}</p>
          <p class="lede">{t(lang, 'hero.lede2')}</p>
          <div class="hero-cta">
            <a class="btn" href={routeMap.prenota[lang]}>{t(lang, 'hero.cta.book')}</a>
            <a class="btn btn-ghost" href={routeMap.menu[lang]}>{t(lang, 'hero.cta.menu')}</a>
          </div>
        </div>
      </article>

      {/* Slide 2 — Biblio Truck */}
      <article class="hero hero-slide hero-slide-truck" style={`--hero-bg: url("${truckOpt.src}")`} aria-roledescription="slide" aria-label="Biblio Truck">
        <div class="hero-inner">
          <p class="hero-truck-title">{t(lang, 'truck.hero.title')}</p>
          <p class="lede">{t(lang, 'truck.hero.tagline')}</p>
          <div class="hero-cta">
            <a class="btn" href={truckHref}>{t(lang, 'hero.truck.cta')}</a>
            <a class="btn btn-ghost" href={eventiHref}>{t(lang, 'home.eventi.cta')}</a>
          </div>
        </div>
      </article>
    </div>
  </div>

  {/* Frecce laterali */}
  <button type="button" class="hero-arrow hero-arrow-prev" data-hero-prev aria-label={t(lang, 'hero.carousel.prev')}>
    <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6" /></svg>
  </button>
  <button type="button" class="hero-arrow hero-arrow-next" data-hero-next aria-label={t(lang, 'hero.carousel.next')}>
    <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6" /></svg>
  </button>

  {/* Pallini, sovrapposti in basso alla slide */}
  <div class="hero-dots" data-hero-dots>
    <button type="button" class="hero-dot is-active" data-hero-dot="0" aria-label={`${goto} 1: Biblio`} aria-current="true"></button>
    <button type="button" class="hero-dot" data-hero-dot="1" aria-label={`${goto} 2: Biblio Truck`} aria-current="false"></button>
  </div>
</section>

<style>
  .hero-carousel {
    position: relative;
    isolation: isolate;
    /* .hero-carousel è un <section>: azzera il padding verticale globale
       (`section { padding: 5rem 0 }`), altrimenti restano due fasce color carta
       sopra/sotto le slide (lo sfondo è sui figli .hero-slide, non sul section). */
    margin: 0;
    padding: 0;
  }
  /* Finestra che ritaglia il track (niente overflow-auto/scroll-snap → niente
     artefatti/fasce su iOS). Lo scorrimento è una translateX sul track. */
  .hero-viewport {
    overflow: hidden;
  }
  .hero-track {
    display: flex;
    will-change: transform;
  }
  /* Ogni slide = larghezza piena della finestra. Riusa .hero (sfondo via
     ::before/--hero-bg che riempie SEMPRE, overlay ::after, tipografia, 88vh). */
  .hero-slide {
    flex: 0 0 100%;
    width: 100%;
  }
  .hero-slide .hero-inner {
    margin-inline: auto;
    width: 100%;
  }

  /* #1 — Centratura OTTICA del logo "Biblio" (solo slide 1). Il box del file SVG
     non è bilanciato: il centro geometrico non coincide col centro visivo della
     scritta (che pende a destra). Compensiamo con un piccolo offset a sinistra. */
  .hero-logo {
    --biblio-logo-visual-offset-x: -12px;
    transform: translateX(var(--biblio-logo-visual-offset-x));
  }
  @media (min-width: 820px) {
    .hero-logo {
      --biblio-logo-visual-offset-x: -16px; /* il logo è più grande su desktop */
    }
  }

  /* #4 — "Biblio Truck" nello stesso rosso del logo Biblio (token). */
  .hero-truck-title {
    margin: 0 auto 2rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(2.6rem, 7vw, 4.4rem);
    line-height: 1;
    color: var(--logo-red);
    filter: drop-shadow(0 3px 18px rgba(0, 0, 0, 0.7));
  }

  /* Frecce laterali */
  .hero-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(38px, 5vw, 52px);
    height: clamp(38px, 5vw, 52px);
    border-radius: 50%;
    border: 1px solid rgba(246, 239, 225, 0.22);
    background: rgba(20, 12, 6, 0.22);
    color: rgba(246, 239, 225, 0.72);
    cursor: pointer;
    backdrop-filter: blur(2px);
    transition: background 0.25s var(--ease), color 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .hero-arrow:hover,
  .hero-arrow:focus-visible {
    background: rgba(20, 12, 6, 0.5);
    color: var(--paper);
    border-color: rgba(246, 239, 225, 0.5);
  }
  .hero-arrow:focus-visible {
    outline: 2px solid var(--paper);
    outline-offset: 3px;
  }
  .hero-arrow-prev {
    left: clamp(0.5rem, 2vw, 1.5rem);
  }
  .hero-arrow-next {
    right: clamp(0.5rem, 2vw, 1.5rem);
  }

  /* Pallini: sovrapposti in basso, centrati. */
  .hero-dots {
    position: absolute;
    left: 50%;
    bottom: clamp(1rem, 3vh, 1.9rem);
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 0.6rem;
    padding: 0.4rem 0.6rem;
    border-radius: 999px;
    background: rgba(20, 12, 6, 0.32);
    backdrop-filter: blur(2px);
  }
  .hero-dot {
    width: 11px;
    height: 11px;
    padding: 0;
    border-radius: 50%;
    border: 1.5px solid var(--paper);
    background: transparent;
    cursor: pointer;
    transition: background 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .hero-dot:hover {
    background: rgba(246, 239, 225, 0.7);
  }
  .hero-dot.is-active {
    background: var(--paper);
    transform: scale(1.1);
  }
  .hero-dot:focus-visible {
    outline: 2px solid var(--paper);
    outline-offset: 3px;
  }

  @media (max-width: 560px) {
    .hero-arrow {
      width: 36px;
      height: 36px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-dot,
    .hero-arrow {
      transition: none;
    }
  }
</style>

<script>
  // Carosello hero: SCORRIMENTO con loop continuo in avanti (clone della prima
  // slide in coda → quando lo si raggiunge, salto istantaneo all'inizio: sembra
  // un loop infinito sempre nello stesso verso, niente ping-pong). Autoplay 5s,
  // frecce, pallini, swipe touch, tastiera. Off con prefers-reduced-motion.
  document.querySelectorAll<HTMLElement>('.hero-carousel').forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>('[data-hero-track]');
    const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>('[data-hero-dot]'));
    const prevBtn = carousel.querySelector<HTMLButtonElement>('[data-hero-prev]');
    const nextBtn = carousel.querySelector<HTMLButtonElement>('[data-hero-next]');
    if (!track || dots.length < 2) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const real = Array.from(track.children) as HTMLElement[];
    const realCount = real.length;

    // Clone della prima slide in coda per il loop continuo in avanti.
    const clone = real[0].cloneNode(true) as HTMLElement;
    clone.setAttribute('aria-hidden', 'true');
    clone.querySelectorAll('a, button').forEach((el) => el.setAttribute('tabindex', '-1'));
    track.appendChild(clone);
    const total = realCount + 1;

    let pos = 0;
    let timer: number | undefined;
    let animating = false;

    const render = (animate: boolean) => {
      track.style.transition = animate && !reduce ? 'transform 0.7s var(--ease)' : 'none';
      track.style.transform = `translateX(-${pos * 100}%)`;
    };
    const setDots = (i: number) => {
      dots.forEach((d, j) => {
        const on = j === i;
        d.classList.toggle('is-active', on);
        d.setAttribute('aria-current', on ? 'true' : 'false');
      });
    };

    const next = () => {
      if (animating) return;
      animating = true;
      pos += 1;
      render(true);
      setDots(pos % realCount);
    };
    const prev = () => {
      if (animating) return;
      animating = true;
      if (pos === 0) {
        // salto istantaneo al clone (identico alla slide 1), poi scorre indietro.
        pos = total - 1;
        render(false);
        requestAnimationFrame(() =>
          requestAnimationFrame(() => {
            pos = total - 2;
            render(true);
            setDots(pos % realCount);
          }),
        );
      } else {
        pos -= 1;
        render(true);
        setDots(pos % realCount);
      }
    };
    const goTo = (i: number) => {
      if (animating || i === pos % realCount) return;
      animating = true;
      pos = i;
      render(true);
      setDots(i);
    };

    // Fine transizione: sblocca e, se siamo sul clone, torna alla slide 1 senza animazione.
    track.addEventListener('transitionend', (e) => {
      if (e.propertyName !== 'transform') return;
      animating = false;
      if (pos === total - 1) {
        pos = 0;
        render(false);
      }
    });

    // Autoplay 5s — sempre in avanti.
    const stop = () => {
      if (timer !== undefined) {
        clearInterval(timer);
        timer = undefined;
      }
    };
    const start = () => {
      if (reduce) return;
      stop();
      timer = window.setInterval(next, 5000);
    };
    const restart = () => {
      stop();
      start();
    };

    dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); restart(); }));
    nextBtn?.addEventListener('click', () => { next(); restart(); });
    prevBtn?.addEventListener('click', () => { prev(); restart(); });

    // Swipe touch.
    let x0: number | null = null;
    track.addEventListener('touchstart', (e) => { x0 = e.changedTouches[0].clientX; }, { passive: true });
    track.addEventListener(
      'touchend',
      (e) => {
        if (x0 === null) return;
        const dx = e.changedTouches[0].clientX - x0;
        if (Math.abs(dx) > 40) {
          if (dx < 0) next();
          else prev();
          restart();
        }
        x0 = null;
      },
      { passive: true },
    );

    document.addEventListener('visibilitychange', () => (document.hidden ? stop() : start()));

    carousel.querySelector('[data-hero-dots]')?.addEventListener('keydown', (ev) => {
      const e = ev as KeyboardEvent;
      if (e.key === 'ArrowRight') { e.preventDefault(); next(); restart(); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); prev(); restart(); }
    });

    render(false);
    setDots(0);
    start();
  });
</script>
