---
import { Image } from 'astro:assets';
import heroSrc from '../assets/img/interni/img_1.webp';
import truckSrc from '../assets/img/truck/bancone.jpg';
import logoSvg from '../assets/img/logo/logo.svg?raw';
import { type Lang, t, routeMap } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Hero-carousel a due viste: slide 1 = bar Biblio (immagine attuale della home),
// slide 2 = Biblio Truck (stessa immagine usata nella pagina /). Gli sfondi sono
// <Image> ottimizzate (webp responsive): la slide 1 è eager + alta priorità (è
// l'LCP della home), la slide 2 è lazy (fuori schermo) così non rallenta il primo
// caricamento. Le due slide restano nel DOM (SEO + scroll-snap anche senza JS).
const truckHref = routeMap.truck[lang];
const eventiHref = routeMap.eventi[lang];
const goto = t(lang, 'hero.carousel.goto');
---

<section class="hero-carousel" aria-roledescription="carousel" aria-label={t(lang, 'hero.carousel.label')}>
  <div class="hero-track" data-hero-track>
    {/* Slide 1 — Bar Biblio: la hero attuale della home, invariata. */}
    <article class="hero hero-slide" aria-roledescription="slide" aria-label="Biblio">
      <div class="hero-media">
        <Image
          src={heroSrc}
          alt=""
          widths={[768, 1280, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="hero-inner">
        <h1 class="hero-logo" set:html={logoSvg} aria-label="Biblio"></h1>
        <p class="lede">{t(lang, 'hero.lede1')}</p>
        <p class="lede">{t(lang, 'hero.lede2')}</p>
        <div class="hero-cta">
          <a class="btn" href={routeMap.prenota[lang]}>{t(lang, 'hero.cta.book')}</a>
          <a class="btn btn-ghost" href={routeMap.menu[lang]}>{t(lang, 'hero.cta.menu')}</a>
        </div>
      </div>
    </article>

    {/* Slide 2 — Biblio Truck: speculare alla slide 1 (stesso trattamento). */}
    <article class="hero hero-slide hero-slide-truck" aria-roledescription="slide" aria-label="Biblio Truck">
      <div class="hero-media">
        <Image
          src={truckSrc}
          alt=""
          widths={[768, 1280, 1920]}
          sizes="100vw"
          loading="lazy"
        />
      </div>
      <div class="hero-inner">
        <p class="hero-truck-title">{t(lang, 'truck.hero.title')}</p>
        <p class="lede">{t(lang, 'truck.hero.tagline')}</p>
        <div class="hero-cta">
          <a class="btn" href={truckHref}>{t(lang, 'hero.truck.cta')}</a>
          <a class="btn btn-ghost" href={eventiHref}>{t(lang, 'home.eventi.cta')}</a>
        </div>
      </div>
    </article>
  </div>

  <div class="hero-dots" data-hero-dots>
    <button type="button" class="hero-dot is-active" data-hero-dot="0" aria-label={`${goto} 1: Biblio`} aria-current="true"></button>
    <button type="button" class="hero-dot" data-hero-dot="1" aria-label={`${goto} 2: Biblio Truck`} aria-current="false"></button>
  </div>
</section>

<style>
  .hero-carousel {
    position: relative;
    isolation: isolate;
  }
  /* Binario scorrevole: scroll-snap orizzontale = swipe nativo su touch e
     trackpad, senza librerie. Le due slide restano nel DOM (SEO + no-JS ok). */
  .hero-track {
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  .hero-track::-webkit-scrollbar {
    display: none; /* WebKit */
  }
  /* Ogni slide riusa la classe .hero (stesso identico trattamento visivo:
     overlay, tipografia, altezza), ma occupa il 100% del binario. */
  .hero-slide {
    flex: 0 0 100%;
    width: 100%;
    scroll-snap-align: start;
  }
  /* Lo sfondo è ora una <Image> ottimizzata (non più il ::before via --hero-bg):
     spegniamo lo pseudo-elemento globale e mettiamo l'immagine come layer. */
  .hero.hero-slide::before {
    display: none;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -2;
    overflow: hidden;
  }
  .hero-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Stesso trattamento del vecchio .hero::before (leggibilità del testo). */
    filter: saturate(1.1) brightness(0.55);
  }

  /* Titolo della slide Truck: speculare al logo della slide 1 (stesso peso
     visivo e stesso margine inferiore del logo). */
  .hero-truck-title {
    margin: 0 auto 2rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2.6rem, 7vw, 4.4rem);
    line-height: 1;
    color: var(--paper);
    filter: drop-shadow(0 4px 24px rgba(0, 0, 0, 0.55));
  }

  /* Indicatori (pallini) */
  .hero-dots {
    position: absolute;
    left: 50%;
    bottom: clamp(1rem, 3vh, 1.9rem);
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    gap: 0.6rem;
    padding: 0.4rem 0.6rem;
    border-radius: 999px;
    background: rgba(20, 12, 6, 0.32);
    backdrop-filter: blur(2px);
  }
  .hero-dot {
    width: 11px;
    height: 11px;
    padding: 0;
    border-radius: 50%;
    border: 1.5px solid var(--paper);
    background: transparent;
    cursor: pointer;
    transition: background 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .hero-dot:hover {
    background: rgba(246, 239, 225, 0.7);
  }
  .hero-dot.is-active {
    background: var(--paper);
    transform: scale(1.1);
  }
  .hero-dot:focus-visible {
    outline: 2px solid var(--paper);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-track {
      scroll-behavior: auto;
    }
    .hero-dot {
      transition: none;
    }
  }
</style>

<script>
  // Carosello hero: navigazione via pallini (click + tastiera) e via swipe/scroll
  // nativo (scroll-snap). Nessun autoplay: scelta deliberata (elegante, niente
  // movimento invadente, performance e prefers-reduced-motion rispettati).
  type Carousel = HTMLElement;
  document.querySelectorAll<Carousel>('.hero-carousel').forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>('[data-hero-track]');
    const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>('[data-hero-dot]'));
    if (!track || dots.length < 2) return;
    const slides = Array.from(track.children) as HTMLElement[];
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const goTo = (i: number) => {
      track.scrollTo({ left: i * track.clientWidth, behavior: reduce ? 'auto' : 'smooth' });
    };
    const setActive = (i: number) => {
      dots.forEach((d, j) => {
        const on = j === i;
        d.classList.toggle('is-active', on);
        d.setAttribute('aria-current', on ? 'true' : 'false');
      });
    };

    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    // Pallino attivo in base alla slide visibile.
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) setActive(slides.indexOf(e.target as HTMLElement));
          }
        },
        { root: track, threshold: 0.6 },
      );
      slides.forEach((s) => io.observe(s));
    } else {
      track.addEventListener(
        'scroll',
        () => setActive(Math.round(track.scrollLeft / track.clientWidth)),
        { passive: true },
      );
    }

    // Tastiera: frecce sui pallini.
    carousel.querySelector('[data-hero-dots]')?.addEventListener('keydown', (ev) => {
      const e = ev as KeyboardEvent;
      const cur = dots.findIndex((d) => d.classList.contains('is-active'));
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        const n = Math.min(cur + 1, slides.length - 1);
        goTo(n);
        dots[n].focus();
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        const n = Math.max(cur - 1, 0);
        goTo(n);
        dots[n].focus();
      }
    });
  });
</script>
