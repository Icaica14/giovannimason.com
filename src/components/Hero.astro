---
import { Image, getImage } from 'astro:assets';
import heroSrc from '../assets/img/interni/img_1.webp';
import truckSrc from '../assets/img/truck/bancone.jpg';
import truckLogo from '../assets/img/logo/biblio-truck.png';
import logoSvg from '../assets/img/logo/logo.svg?raw';
import { type Lang, t, routeMap } from '../i18n/ui';

interface Props {
  lang: Lang;
  /**
   * Mostrare il carosello Biblio Truck. Default true.
   * false → hero STATICA del solo bar Biblio (niente seconda slide, frecce,
   * pallini, transizioni o contenitori del carosello): una home pulita.
   */
  carousel?: boolean;
}
const { lang, carousel = true } = Astro.props;

// Sfondi delle slide come CSS background `cover` (riempiono sempre la slide →
// nessuna fascia su iOS Safari). Lo scorrimento è una translateX sul track flex,
// con loop continuo in avanti (clone della prima slide) → niente ping-pong.
const barOpt = await getImage({ src: heroSrc, width: 1600, format: 'webp', quality: 80 });
const truckOpt = await getImage({ src: truckSrc, width: 1600, format: 'webp', quality: 78 });

const truckHref = routeMap.truck[lang];
const eventiHref = routeMap.eventi[lang];
const goto = t(lang, 'hero.carousel.goto');
const truckName = t(lang, 'truck.hero.title'); // "Biblio Truck" — alt del logo
---

<section
  class:list={['hero-carousel', { 'is-static': !carousel }]}
  aria-roledescription={carousel ? 'carousel' : undefined}
  aria-label={carousel ? t(lang, 'hero.carousel.label') : undefined}
>
  <div class="hero-viewport">
    <div class="hero-track" data-hero-track>
      {/* Slide 1 — Bar Biblio (sempre presente, anche in modalità statica) */}
      <article
        class="hero hero-slide"
        style={`--hero-bg: url("${barOpt.src}")`}
        aria-roledescription={carousel ? 'slide' : undefined}
        aria-label="Biblio"
      >
        <div class="hero-inner">
          <div class="hero-brand">
            <h1 class="hero-brand-logo hero-logo-biblio" set:html={logoSvg} aria-label="Biblio"></h1>
          </div>
          <div class="hero-copy">
            <p class="lede">{t(lang, 'hero.lede1')}</p>
            <p class="lede">{t(lang, 'hero.lede2')}</p>
          </div>
          <div class="hero-cta">
            <a class="btn" href={routeMap.prenota[lang]}>{t(lang, 'hero.cta.book')}</a>
            <a class="btn btn-ghost" href={routeMap.menu[lang]}>{t(lang, 'hero.cta.menu')}</a>
          </div>
        </div>
      </article>

      {/* Slide 2 — Biblio Truck (solo a carosello attivo) */}
      {carousel && (
        <article
          class="hero hero-slide hero-slide-truck"
          style={`--hero-bg: url("${truckOpt.src}")`}
          aria-roledescription="slide"
          aria-label="Biblio Truck"
        >
          <div class="hero-inner">
            <div class="hero-brand">
              <p class="hero-brand-logo hero-logo-truck">
                <Image src={truckLogo} alt={truckName} widths={[320, 480, 640, 820]} sizes="(max-width: 560px) 70vw, 460px" loading="eager" />
              </p>
            </div>
            <div class="hero-copy">
              <p class="lede">{t(lang, 'truck.hero.tagline')}</p>
              <p class="lede">{t(lang, 'truck.hero.tagline2')}</p>
            </div>
            <div class="hero-cta">
              <a class="btn" href={truckHref}>{t(lang, 'hero.truck.cta')}</a>
              <a class="btn btn-ghost" href={eventiHref}>{t(lang, 'home.eventi.cta')}</a>
            </div>
          </div>
        </article>
      )}
    </div>
  </div>

  {/* Frecce + pallini: solo a carosello attivo */}
  {carousel && (
    <Fragment>
      <button type="button" class="hero-arrow hero-arrow-prev" data-hero-prev aria-label={t(lang, 'hero.carousel.prev')}>
        <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6" /></svg>
      </button>
      <button type="button" class="hero-arrow hero-arrow-next" data-hero-next aria-label={t(lang, 'hero.carousel.next')}>
        <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6" /></svg>
      </button>

      <div class="hero-dots" data-hero-dots>
        <button type="button" class="hero-dot is-active" data-hero-dot="0" aria-label={`${goto} 1: Biblio`} aria-current="true"></button>
        <button type="button" class="hero-dot" data-hero-dot="1" aria-label={`${goto} 2: Biblio Truck`} aria-current="false"></button>
      </div>
    </Fragment>
  )}
</section>

<style>
  .hero-carousel {
    position: relative;
    isolation: isolate;
    /* .hero-carousel è un <section>: azzera il padding verticale globale
       (`section { padding: 5rem 0 }`), altrimenti restano due fasce color carta
       sopra/sotto le slide (lo sfondo è sui figli .hero-slide, non sul section). */
    margin: 0;
    padding: 0;
  }
  .hero-viewport {
    overflow: hidden;
  }
  .hero-track {
    display: flex;
    will-change: transform;
  }
  /* Ogni slide = larghezza piena della finestra. Riusa .hero (sfondo via
     ::before/--hero-bg che riempie SEMPRE, overlay ::after, tipografia, 88vh). */
  .hero-slide {
    flex: 0 0 100%;
    width: 100%;
  }
  /* L'inner riempie l'altezza della slide (le due slide sono già di pari altezza):
     logo IN ALTO, CTA IN BASSO, testo centrato nel mezzo → logo e pulsanti
     restano alla STESSA quota nelle due slide, nessun salto al cambio slide. */
  .hero-slide {
    align-items: stretch;
  }
  .hero-slide .hero-inner {
    margin-inline: auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Uniformità delle due slide ───────────────────────────────────────────
     Composizione identica: [zona logo] + [copy] + [CTA]. La ZONA LOGO ha la
     STESSA ALTEZZA in entrambe le slide → il blocco non "salta" né cambia
     dimensione al cambio slide. Il logo Biblio (emblema ~quadrato) riempie la
     zona; il logo Biblio Truck (wordmark 2 righe, più largo) è limitato in
     altezza così la sua larghezza resta equilibrata e centrata nella stessa zona. */
  .hero-brand {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    height: clamp(165px, 30vw, 300px);
    margin: 0 auto 1.6rem;
  }
  .hero-brand-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    max-width: 100%;
    margin: 0;
    line-height: 0;
  }
  /* Il logo Biblio (SVG bicolore via set:html → non scoped: serve :global). */
  .hero-logo-biblio {
    color: var(--logo-red);
    --logo-ink: var(--paper);
    /* Centratura OTTICA: il box dell'SVG non è bilanciato (la scritta pende a
       destra). Piccolo offset a sinistra per centrarlo visivamente. */
    --biblio-logo-visual-offset-x: -10px;
    transform: translateX(var(--biblio-logo-visual-offset-x));
  }
  .hero-logo-biblio :global(svg) {
    display: block;
    height: 100%;
    width: auto;
    max-width: 100%;
    filter: drop-shadow(0 4px 24px rgba(0, 0, 0, 0.55));
  }
  /* Il logo Biblio Truck (PNG trasparente). Altezza definita al ~78% della zona
     (così il wordmark largo non domina e i due loghi appaiono bilanciati); la
     larghezza segue l'aspect, anche prima del load (niente collasso a 0). */
  .hero-logo-truck :global(img) {
    display: block;
    height: 67%;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    filter: drop-shadow(0 4px 20px rgba(0, 0, 0, 0.5));
  }
  @media (min-width: 820px) {
    .hero-logo-biblio {
      --biblio-logo-visual-offset-x: -14px;
    }
  }

  /* Zona testo a altezza riservata: la CTA resta alla stessa quota in entrambe
     le slide anche se una ha due righe di copy e l'altra una. */
  .hero-copy {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
  }
  .hero-copy .lede:last-child {
    margin-bottom: 0;
  }
  .hero-cta {
    flex: 0 0 auto;
    margin-top: 1.6rem;
  }

  /* Frecce laterali */
  .hero-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(38px, 5vw, 52px);
    height: clamp(38px, 5vw, 52px);
    border-radius: 50%;
    border: 1px solid rgba(246, 239, 225, 0.22);
    background: rgba(20, 12, 6, 0.22);
    color: rgba(246, 239, 225, 0.72);
    cursor: pointer;
    backdrop-filter: blur(2px);
    transition: background 0.25s var(--ease), color 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .hero-arrow:hover,
  .hero-arrow:focus-visible {
    background: rgba(20, 12, 6, 0.5);
    color: var(--paper);
    border-color: rgba(246, 239, 225, 0.5);
  }
  .hero-arrow:focus-visible {
    outline: 2px solid var(--paper);
    outline-offset: 3px;
  }
  .hero-arrow-prev {
    left: clamp(0.5rem, 2vw, 1.5rem);
  }
  .hero-arrow-next {
    right: clamp(0.5rem, 2vw, 1.5rem);
  }

  /* Pallini: sovrapposti in basso, centrati. */
  .hero-dots {
    position: absolute;
    left: 50%;
    bottom: clamp(1rem, 3vh, 1.9rem);
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 0.6rem;
    padding: 0.4rem 0.6rem;
    border-radius: 999px;
    background: rgba(20, 12, 6, 0.32);
    backdrop-filter: blur(2px);
  }
  .hero-dot {
    width: 11px;
    height: 11px;
    padding: 0;
    border-radius: 50%;
    border: 1.5px solid var(--paper);
    background: transparent;
    cursor: pointer;
    transition: background 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .hero-dot:hover {
    background: rgba(246, 239, 225, 0.7);
  }
  .hero-dot.is-active {
    background: var(--paper);
    transform: scale(1.1);
  }
  .hero-dot:focus-visible {
    outline: 2px solid var(--paper);
    outline-offset: 3px;
  }

  @media (max-width: 560px) {
    .hero-arrow {
      width: 36px;
      height: 36px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-dot,
    .hero-arrow {
      transition: none;
    }
  }
</style>

<script>
  // Carosello hero: SCORRIMENTO con loop continuo in avanti (clone della prima
  // slide in coda → quando lo si raggiunge, salto istantaneo all'inizio: sembra
  // un loop infinito sempre nello stesso verso, niente ping-pong). Autoplay 5s,
  // frecce, pallini, swipe touch, tastiera. Off con prefers-reduced-motion.
  // In modalità STATICA (una sola slide, nessun pallino) la guardia
  // `dots.length < 2` esce subito: nessun clone, nessun autoplay, nessuna chrome.
  document.querySelectorAll<HTMLElement>('.hero-carousel').forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>('[data-hero-track]');
    const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>('[data-hero-dot]'));
    const prevBtn = carousel.querySelector<HTMLButtonElement>('[data-hero-prev]');
    const nextBtn = carousel.querySelector<HTMLButtonElement>('[data-hero-next]');
    if (!track || dots.length < 2) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const real = Array.from(track.children) as HTMLElement[];
    const realCount = real.length;

    // Clone della prima slide in coda per il loop continuo in avanti.
    const clone = real[0].cloneNode(true) as HTMLElement;
    clone.setAttribute('aria-hidden', 'true');
    clone.querySelectorAll('a, button').forEach((el) => el.setAttribute('tabindex', '-1'));
    track.appendChild(clone);
    const total = realCount + 1;

    let pos = 0;
    let timer: number | undefined;
    let settleTimer: number | undefined;
    let animating = false;

    // Completa il ciclo a fine scorrimento: sblocca e, se siamo sul clone
    // (ultima cella = slide 1), torna all'inizio senza animazione → loop infinito.
    const afterSettle = () => {
      if (settleTimer !== undefined) {
        clearTimeout(settleTimer);
        settleTimer = undefined;
      }
      animating = false;
      if (pos === total - 1) {
        pos = 0;
        render(false);
      }
    };
    const render = (animate: boolean) => {
      const willAnimate = animate && !reduce;
      track.style.transition = willAnimate ? 'transform 0.7s var(--ease)' : 'none';
      track.style.transform = `translateX(-${pos * 100}%)`;
      // Rete di sicurezza: completa il ciclo anche se `transitionend` NON scatta —
      // con reduced-motion (transition 'none') o con la tab in background (le
      // transizioni vanno in pausa). Senza, `animating` resterebbe bloccato e la
      // navigazione manuale si freezerebbe. setTimeout scatta anche da nascosti.
      if (animate) {
        if (settleTimer !== undefined) clearTimeout(settleTimer);
        settleTimer = window.setTimeout(afterSettle, willAnimate ? 820 : 60);
      }
    };
    const setDots = (i: number) => {
      dots.forEach((d, j) => {
        const on = j === i;
        d.classList.toggle('is-active', on);
        d.setAttribute('aria-current', on ? 'true' : 'false');
      });
    };

    const next = () => {
      if (animating) return;
      animating = true;
      pos += 1;
      render(true);
      setDots(pos % realCount);
    };
    const prev = () => {
      if (animating) return;
      animating = true;
      if (pos === 0) {
        // salto istantaneo al clone (identico alla slide 1), poi scorre indietro.
        pos = total - 1;
        render(false);
        requestAnimationFrame(() =>
          requestAnimationFrame(() => {
            pos = total - 2;
            render(true);
            setDots(pos % realCount);
          }),
        );
      } else {
        pos -= 1;
        render(true);
        setDots(pos % realCount);
      }
    };
    const goTo = (i: number) => {
      if (animating || i === pos % realCount) return;
      animating = true;
      pos = i;
      render(true);
      setDots(i);
    };

    // Fine transizione (solo con motion attivo): stesso epilogo del settleTimer.
    // afterSettle() annulla il timer di sicurezza ancora pendente → niente doppio
    // sblocco quando la transizione completa prima del timeout di backstop.
    track.addEventListener('transitionend', (e) => {
      if (e.propertyName !== 'transform') return;
      afterSettle();
    });

    // Autoplay 5s — sempre in avanti.
    const stop = () => {
      if (timer !== undefined) {
        clearInterval(timer);
        timer = undefined;
      }
    };
    const start = () => {
      if (reduce) return;
      stop();
      timer = window.setInterval(next, 5000);
    };
    const restart = () => {
      stop();
      start();
    };

    dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); restart(); }));
    nextBtn?.addEventListener('click', () => { next(); restart(); });
    prevBtn?.addEventListener('click', () => { prev(); restart(); });

    // Swipe touch.
    let x0: number | null = null;
    track.addEventListener('touchstart', (e) => { x0 = e.changedTouches[0].clientX; }, { passive: true });
    track.addEventListener(
      'touchend',
      (e) => {
        if (x0 === null) return;
        const dx = e.changedTouches[0].clientX - x0;
        if (Math.abs(dx) > 40) {
          if (dx < 0) next();
          else prev();
          restart();
        }
        x0 = null;
      },
      { passive: true },
    );

    document.addEventListener('visibilitychange', () => (document.hidden ? stop() : start()));

    carousel.querySelector('[data-hero-dots]')?.addEventListener('keydown', (ev) => {
      const e = ev as KeyboardEvent;
      if (e.key === 'ArrowRight') { e.preventDefault(); next(); restart(); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); prev(); restart(); }
    });

    render(false);
    setDots(0);
    start();
  });
</script>
