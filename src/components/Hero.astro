---
import { Image } from 'astro:assets';
import heroSrc from '../assets/img/interni/img_1.webp';
import truckSrc from '../assets/img/truck/bancone.jpg';
import logoSvg from '../assets/img/logo/logo.svg?raw';
import { type Lang, t, routeMap } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Hero-carousel a due viste (slide 1 = bar Biblio, slide 2 = Biblio Truck) con
// CROSSFADE: le slide sono impilate e si dissolvono l'una nell'altra. Niente
// track scrollabile orizzontale → niente effetto "ping-pong" avanti/indietro e
// niente artefatti/fasce dell'overflow su iOS Safari. Sfondi <Image> ottimizzate
// (slide 1 eager + fetchpriority high = LCP; slide 2 lazy).
const truckHref = routeMap.truck[lang];
const eventiHref = routeMap.eventi[lang];
const goto = t(lang, 'hero.carousel.goto');
---

<section class="hero-carousel" aria-roledescription="carousel" aria-label={t(lang, 'hero.carousel.label')}>
  <div class="hero-stage" data-hero-stage>
    {/* Slide 1 — Bar Biblio */}
    <article class="hero hero-slide is-current" aria-roledescription="slide" aria-label="Biblio">
      <div class="hero-media">
        <Image src={heroSrc} alt="" widths={[768, 1280, 1920]} sizes="100vw" loading="eager" fetchpriority="high" />
      </div>
      <div class="hero-inner">
        <h1 class="hero-logo" set:html={logoSvg} aria-label="Biblio"></h1>
        <p class="lede">{t(lang, 'hero.lede1')}</p>
        <p class="lede">{t(lang, 'hero.lede2')}</p>
        <div class="hero-cta">
          <a class="btn" href={routeMap.prenota[lang]}>{t(lang, 'hero.cta.book')}</a>
          <a class="btn btn-ghost" href={routeMap.menu[lang]}>{t(lang, 'hero.cta.menu')}</a>
        </div>
      </div>
    </article>

    {/* Slide 2 — Biblio Truck: speculare alla slide 1 */}
    <article class="hero hero-slide hero-slide-truck" aria-roledescription="slide" aria-label="Biblio Truck" aria-hidden="true">
      <div class="hero-media">
        <Image src={truckSrc} alt="" widths={[768, 1280, 1920]} sizes="100vw" loading="lazy" />
      </div>
      <div class="hero-inner">
        <p class="hero-truck-title">{t(lang, 'truck.hero.title')}</p>
        <p class="lede">{t(lang, 'truck.hero.tagline')}</p>
        <div class="hero-cta">
          <a class="btn" href={truckHref}>{t(lang, 'hero.truck.cta')}</a>
          <a class="btn btn-ghost" href={eventiHref}>{t(lang, 'home.eventi.cta')}</a>
        </div>
      </div>
    </article>
  </div>

  {/* Frecce laterali */}
  <button type="button" class="hero-arrow hero-arrow-prev" data-hero-prev aria-label={t(lang, 'hero.carousel.prev')}>
    <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6" /></svg>
  </button>
  <button type="button" class="hero-arrow hero-arrow-next" data-hero-next aria-label={t(lang, 'hero.carousel.next')}>
    <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6" /></svg>
  </button>

  {/* Pallini */}
  <div class="hero-dots" data-hero-dots>
    <button type="button" class="hero-dot is-active" data-hero-dot="0" aria-label={`${goto} 1: Biblio`} aria-current="true"></button>
    <button type="button" class="hero-dot" data-hero-dot="1" aria-label={`${goto} 2: Biblio Truck`} aria-current="false"></button>
  </div>
</section>

<style>
  .hero-carousel {
    position: relative;
    isolation: isolate;
    margin: 0; /* full-bleed: nessuno spazio sopra/sotto */
  }
  /* Le due slide sono IMPILATE nella stessa cella di griglia (crossfade), niente
     contenitore scrollabile: così non c'è la fascia/artefatto dell'overflow iOS. */
  .hero-stage {
    display: grid;
  }
  .hero-slide {
    grid-area: 1 / 1;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.8s var(--ease), visibility 0s 0.8s;
    pointer-events: none;
  }
  .hero-slide.is-current {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.8s var(--ease);
    pointer-events: auto;
    z-index: 1;
  }
  /* Sfondo via <Image>: spegniamo lo ::before globale (--hero-bg). */
  .hero.hero-slide::before {
    display: none;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -2;
    overflow: hidden;
  }
  .hero-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.1) brightness(0.55);
  }
  .hero-slide .hero-inner {
    margin-inline: auto;
    width: 100%;
  }

  /* #1 — Centratura OTTICA del logo "Biblio" (solo slide 1, l'unica con .hero-logo).
     Il box del file SVG non è bilanciato: il centro geometrico non coincide col
     centro visivo della scritta, che appare spostata a destra. Compensiamo con un
     piccolo spostamento a sinistra, regolabile via variabile. */
  .hero-logo {
    --biblio-logo-visual-offset-x: -12px;
    transform: translateX(var(--biblio-logo-visual-offset-x));
  }
  @media (min-width: 820px) {
    .hero-logo {
      --biblio-logo-visual-offset-x: -16px; /* il logo è più grande su desktop */
    }
  }

  /* #4 — "Biblio Truck" nello stesso rosso del logo Biblio (token). */
  .hero-truck-title {
    margin: 0 auto 2rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(2.6rem, 7vw, 4.4rem);
    line-height: 1;
    color: var(--logo-red);
    filter: drop-shadow(0 3px 18px rgba(0, 0, 0, 0.7));
  }

  /* Frecce laterali: neutre, più visibili su hover/focus. */
  .hero-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(38px, 5vw, 52px);
    height: clamp(38px, 5vw, 52px);
    border-radius: 50%;
    border: 1px solid rgba(246, 239, 225, 0.22);
    background: rgba(20, 12, 6, 0.22);
    color: rgba(246, 239, 225, 0.72);
    cursor: pointer;
    backdrop-filter: blur(2px);
    transition: background 0.25s var(--ease), color 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .hero-arrow:hover,
  .hero-arrow:focus-visible {
    background: rgba(20, 12, 6, 0.5);
    color: var(--paper);
    border-color: rgba(246, 239, 225, 0.5);
  }
  .hero-arrow:focus-visible {
    outline: 2px solid var(--paper);
    outline-offset: 3px;
  }
  .hero-arrow-prev {
    left: clamp(0.5rem, 2vw, 1.5rem);
  }
  .hero-arrow-next {
    right: clamp(0.5rem, 2vw, 1.5rem);
  }

  /* Pallini: sovrapposti in basso, centrati. */
  .hero-dots {
    position: absolute;
    left: 50%;
    bottom: clamp(1rem, 3vh, 1.9rem);
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 0.6rem;
    padding: 0.4rem 0.6rem;
    border-radius: 999px;
    background: rgba(20, 12, 6, 0.32);
    backdrop-filter: blur(2px);
  }
  .hero-dot {
    width: 11px;
    height: 11px;
    padding: 0;
    border-radius: 50%;
    border: 1.5px solid var(--paper);
    background: transparent;
    cursor: pointer;
    transition: background 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .hero-dot:hover {
    background: rgba(246, 239, 225, 0.7);
  }
  .hero-dot.is-active {
    background: var(--paper);
    transform: scale(1.1);
  }
  .hero-dot:focus-visible {
    outline: 2px solid var(--paper);
    outline-offset: 3px;
  }

  @media (max-width: 560px) {
    .hero-arrow {
      width: 36px;
      height: 36px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-slide,
    .hero-dot,
    .hero-arrow {
      transition: none;
    }
  }
</style>

<script>
  // Carosello hero: CROSSFADE (niente ping-pong), pallini, frecce, swipe touch e
  // autoplay ogni 5s che avanza sempre nello stesso verso. Riparte dopo ogni
  // interazione, si ferma in background, resta OFF con prefers-reduced-motion.
  document.querySelectorAll<HTMLElement>('.hero-carousel').forEach((carousel) => {
    const stage = carousel.querySelector<HTMLElement>('[data-hero-stage]');
    const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>('[data-hero-dot]'));
    const prev = carousel.querySelector<HTMLButtonElement>('[data-hero-prev]');
    const next = carousel.querySelector<HTMLButtonElement>('[data-hero-next]');
    if (!stage || dots.length < 2) return;
    const slides = Array.from(stage.children) as HTMLElement[];
    const count = slides.length;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let index = 0;
    let timer: number | undefined;

    const setCurrent = (i: number) => {
      index = (i + count) % count;
      slides.forEach((s, j) => {
        const on = j === index;
        s.classList.toggle('is-current', on);
        s.setAttribute('aria-hidden', on ? 'false' : 'true');
      });
      dots.forEach((d, j) => {
        const on = j === index;
        d.classList.toggle('is-active', on);
        d.setAttribute('aria-current', on ? 'true' : 'false');
      });
    };

    // Autoplay 5s — avanza SEMPRE in avanti (index+1), crossfade ⇒ niente ping-pong.
    const AUTOPLAY = 5000;
    const stop = () => {
      if (timer !== undefined) {
        clearInterval(timer);
        timer = undefined;
      }
    };
    const start = () => {
      if (reduce) return;
      stop();
      timer = window.setInterval(() => setCurrent(index + 1), AUTOPLAY);
    };
    const restart = () => {
      stop();
      start();
    };
    const navTo = (i: number) => {
      setCurrent(i);
      restart(); // dopo un'interazione il timer riparte da capo, senza scatti
    };

    dots.forEach((dot, i) => dot.addEventListener('click', () => navTo(i)));
    prev?.addEventListener('click', () => navTo(index - 1));
    next?.addEventListener('click', () => navTo(index + 1));

    // Swipe leggero (touch): qualunque direzione naviga (crossfade ⇒ niente "indietro").
    let x0: number | null = null;
    stage.addEventListener('touchstart', (e) => { x0 = e.changedTouches[0].clientX; }, { passive: true });
    stage.addEventListener(
      'touchend',
      (e) => {
        if (x0 === null) return;
        const dx = e.changedTouches[0].clientX - x0;
        if (Math.abs(dx) > 40) navTo(index + (dx < 0 ? 1 : -1));
        x0 = null;
      },
      { passive: true },
    );

    // Niente avanzamenti quando la scheda è nascosta (e nessun leak).
    document.addEventListener('visibilitychange', () => (document.hidden ? stop() : start()));

    // Tastiera: frecce sui pallini.
    carousel.querySelector('[data-hero-dots]')?.addEventListener('keydown', (ev) => {
      const e = ev as KeyboardEvent;
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        navTo(index + 1);
        dots[index].focus();
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        navTo(index - 1);
        dots[index].focus();
      }
    });

    setCurrent(0);
    start();
  });
</script>
