---
import { Image } from 'astro:assets';
import { type Lang, t, routeMap } from '../i18n/ui';
import { splitEventi, eventDateLabel } from '../data/eventi';
import { getEvents } from '../data/eventiRemote';
import { getTruckMenus } from '../data/truckMenus';

// Foto del food truck (caricate dal titolare).
// bancone.jpg → landscape, usata come banda hero di sfondo.
// truck.jpg   → portrait, usata nel racconto del progetto (intro-grid).
import bancone from '../assets/img/truck/bancone.jpg';
import truck from '../assets/img/truck/truck.jpg';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Eventi ai Giardinetti, solo i prossimi. Stessa fonte/handler degli eventi
// del sito (Supabase a build-time, fallback content collection): così il
// manager li modifica dalla stessa app gestione, scegliendo luogo = Giardinetti.
const entries = await getEvents();
const todayISO = new Date().toISOString().slice(0, 10);
const { upcoming } = splitEventi(entries, todayISO);
const giardinetti = upcoming.filter((e) => e.data.venue === 'giardinetti');

// PDF dei menu (food/drink): pubblici, sostituibili dall'app gestione.
const menus = await getTruckMenus();

const instagram = 'https://www.instagram.com/biblio_treviso/';

// Posizione dei Giardinetti di Sant'Andrea (Treviso, lungo il Sile).
const mapQuery = "Giardino di Sant'Andrea, Treviso";
const mapEmbed = `https://www.google.com/maps?q=${encodeURIComponent(mapQuery)}&output=embed`;
const mapLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(mapQuery)}`;

const heroAlt = lang === 'it'
  ? 'Il bancone del food truck di Biblio ai Giardinetti, fra le luci della sera'
  : "Biblio's food-truck counter at the Giardinetti, among the evening lights";
const truckAlt = lang === 'it'
  ? 'Il food truck di Biblio parcheggiato fra gli alberi dei Giardinetti di Sant’Andrea'
  : "Biblio's food truck parked among the trees at the Giardinetti di Sant'Andrea";
---

<section class="truck-page">
  {/* Hero band con foto del bancone */}
  <header class="truck-hero">
    <div class="truck-hero-media">
      <Image
        src={bancone}
        alt={heroAlt}
        widths={[640, 960, 1280, 1920, 2400]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
      <span class="truck-hero-veil" aria-hidden="true"></span>
    </div>
    <div class="truck-hero-inner container">
      <span class="eyebrow">{t(lang, 'truck.hero.eyebrow')}</span>
      <h1>{t(lang, 'truck.hero.title')}</h1>
      <p class="truck-hero-tagline">{t(lang, 'truck.hero.tagline')}</p>
    </div>
  </header>

  {/* Il progetto: racconto + foto del truck */}
  <section class="container">
    <div class="intro-grid">
      <Image
        class="reveal truck-portrait"
        src={truck}
        alt={truckAlt}
        widths={[480, 720, 960, 1280]}
        sizes="(max-width: 820px) 100vw, 480px"
        loading="lazy"
      />
      <div class="prose reveal" style="--reveal-delay:.1s">
        <span class="eyebrow">{t(lang, 'truck.intro.eyebrow')}</span>
        <h2>{t(lang, 'truck.intro.title')}</h2>
        <p>{t(lang, 'truck.intro.body')}</p>
        <p>{t(lang, 'truck.intro.body2')}</p>
      </div>
    </div>
  </section>

  <div class="divider"><span>· · ·</span></div>

  {/* Menu food & drink (PDF) */}
  <section class="bg-paper-2">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">{t(lang, 'truck.menus.eyebrow')}</span>
        <h2>{t(lang, 'truck.menus.title')}</h2>
        <p>{t(lang, 'truck.menus.intro')}</p>
      </div>
      <div class="truck-menu-actions reveal">
        <a class="btn" href={menus.food} target="_blank" rel="noopener noreferrer">
          {t(lang, 'truck.menus.food')}
        </a>
        <a class="btn btn-dark" href={menus.drink} target="_blank" rel="noopener noreferrer">
          {t(lang, 'truck.menus.drink')}
        </a>
      </div>
    </div>
  </section>

  {/* Prossimi eventi ai Giardinetti (senza immagini) */}
  <section class="truck-events">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">{t(lang, 'truck.events.eyebrow')}</span>
        <h2>{t(lang, 'truck.events.title')}</h2>
        <p>{t(lang, 'truck.events.intro')}</p>
      </div>

      {giardinetti.length === 0 ? (
        <p class="truck-events-empty reveal">{t(lang, 'truck.events.empty')}</p>
      ) : (
        <ul class="truck-events-list reveal">
          {giardinetti.map((ev) => (
            <li>
              <a class="truck-event" href={`${routeMap.eventi[lang]}#${ev.id}`}>
                <span class="truck-event-date">{eventDateLabel(ev.data, lang)}</span>
                <span class="truck-event-main">
                  <span class="truck-event-artist">{ev.data.artist}</span>
                  <span class="truck-event-time">{ev.data.time}</span>
                </span>
                <span class="truck-event-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      )}

      <p class="truck-events-cta reveal">
        <a class="btn btn-dark" href={routeMap.eventi[lang]}>{t(lang, 'truck.events.cta')}</a>
      </p>
    </div>
  </section>

  {/* Dove: posizione dei Giardinetti */}
  <section class="truck-where bg-paper-2">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">{t(lang, 'truck.location.eyebrow')}</span>
        <h2>{t(lang, 'truck.location.title')}</h2>
        <p>{t(lang, 'truck.location.body')}</p>
      </div>
      <div class="truck-map reveal">
        <iframe
          title={t(lang, 'truck.location.map')}
          src={mapEmbed}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      <p class="truck-map-cta reveal">
        <a class="btn btn-dark" href={mapLink} target="_blank" rel="noopener noreferrer">
          {t(lang, 'truck.location.cta')}
        </a>
      </p>
    </div>
  </section>

  {/* CTA finale: solo info, niente prenotazione */}
  <section class="cta-banner reveal">
    <span class="eyebrow">{t(lang, 'truck.cta.eyebrow')}</span>
    <h2>{t(lang, 'truck.cta.title')}</h2>
    <p>{t(lang, 'truck.cta.body')}</p>
    <div class="truck-cta-actions">
      <a class="btn" href={routeMap.eventi[lang]}>{t(lang, 'truck.cta.events')}</a>
      <a class="btn btn-ghost" href={instagram} target="_blank" rel="noopener noreferrer">
        {t(lang, 'truck.cta.instagram')}
      </a>
    </div>
  </section>
</section>

<style>
  /* ---- Hero band ---- */
  .truck-hero {
    position: relative;
    display: grid;
    align-items: end;
    min-height: clamp(360px, 56vh, 560px);
    padding: 0;
    overflow: hidden;
  }
  .truck-hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .truck-hero-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .truck-hero-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(20, 12, 6, 0.86) 0%,
      rgba(20, 12, 6, 0.5) 42%,
      rgba(20, 12, 6, 0.2) 100%
    );
  }
  .truck-hero-inner {
    position: relative;
    z-index: 1;
    padding-block: 2.5rem 3rem;
    text-align: center;
    color: var(--paper);
  }
  .truck-hero-inner .eyebrow {
    color: var(--brass);
  }
  .truck-hero-inner h1 {
    color: var(--paper);
    font-style: italic;
    font-size: clamp(2.6rem, 7vw, 4.4rem);
    margin: 0.2rem 0 0.8rem;
  }
  .truck-hero-tagline {
    color: var(--paper-3);
    font-size: clamp(1.05rem, 2.4vw, 1.3rem);
    max-width: 44ch;
    margin: 0 auto;
  }

  /* La foto portrait del truck nel racconto: ratio nativa (5:7) → nessun
     ritaglio, con una larghezza massima così non domina la colonna. */
  .truck-portrait {
    aspect-ratio: 5 / 7;
    max-width: 26rem;
    margin-inline: auto;
  }

  /* ---- Bottoni menu PDF ---- */
  .truck-menu-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  /* ---- Dove: mappa dei Giardinetti ---- */
  .truck-map {
    max-width: 56rem;
    margin: 0 auto;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-warm);
    border: 1px solid var(--line);
    line-height: 0;
  }
  .truck-map iframe {
    display: block;
    width: 100%;
    height: clamp(260px, 42vh, 420px);
    border: 0;
  }
  .truck-map-cta {
    text-align: center;
    margin: 1.5rem 0 0;
  }

  /* ---- Lista eventi (no immagini) ---- */
  .truck-events-empty {
    text-align: center;
    font-style: italic;
    color: var(--ink-soft);
    max-width: 56ch;
    margin: 0 auto;
  }
  .truck-events-list {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 44rem;
    display: grid;
    gap: 0.75rem;
  }
  .truck-event {
    display: grid;
    grid-template-columns: minmax(8.5rem, auto) 1fr auto;
    align-items: center;
    gap: 1.25rem;
    padding: 1.1rem 1.4rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-warm);
    color: var(--ink);
    transition: transform 0.2s var(--ease), border-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  .truck-event:hover {
    transform: translateY(-2px);
    border-color: var(--brass);
    color: var(--ink);
  }
  .truck-event-date {
    font-family: var(--font-brand);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brass-deep);
  }
  .truck-event-main {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .truck-event-artist {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--ink);
  }
  .truck-event-time {
    font-size: 0.9rem;
    color: var(--ink-soft);
  }
  .truck-event-arrow {
    font-size: 1.2rem;
    color: var(--brass-deep);
    transition: transform 0.2s var(--ease);
  }
  .truck-event:hover .truck-event-arrow {
    transform: translateX(3px);
  }
  .truck-events-cta {
    text-align: center;
    margin: 2.5rem 0 0;
  }

  /* ---- CTA finale ---- */
  .truck-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    justify-content: center;
  }

  @media (max-width: 560px) {
    .truck-event {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        'date arrow'
        'main main';
      gap: 0.5rem 1rem;
    }
    .truck-event-date {
      grid-area: date;
    }
    .truck-event-arrow {
      grid-area: arrow;
      justify-self: end;
    }
    .truck-event-main {
      grid-area: main;
    }
  }
</style>
