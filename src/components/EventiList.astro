---
import { type Lang, t, routeMap } from '../i18n/ui';
import { genreLabel, splitEventi, tx, eventDateLabel, eventBlurb, eventVenue, VENUE_DEFAULT, eventStatus, eventStatusNote, statusLabel } from '../data/eventi';
import { getEvents } from '../data/eventiRemote';
import { musicEventLd } from '../lib/structuredData';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Oggi è passato lato server: gli eventi futuri/passati vengono congelati al build.
// (Il sito è statico, perfettamente coerente con un calendario aggiornato a ogni deploy.)
// Fonte: Supabase a build-time (fallback alla content collection del repo).
const entries = await getEvents();
const todayISO = new Date().toISOString().slice(0, 10);
const { upcoming, past } = splitEventi(entries, todayISO);

// Base URL assoluto per i dati strutturati MusicEvent (immagini, location, offers).
const siteOrigin = Astro.site ? Astro.site.origin : '';
---

<section class="eventi-page">
  <header class="eventi-hero container">
    <span class="eyebrow">{t(lang, 'hero.tagline')}</span>
    <h1>{t(lang, 'eventi.title')}</h1>
    <p class="lede">{t(lang, 'eventi.lede')}</p>
  </header>

  {/* In arrivo */}
  <section class="eventi-upcoming bg-paper-2">
    <div class="container">
      <div class="section-head">
        <h2>{t(lang, 'eventi.upcoming.title')}</h2>
      </div>

      {upcoming.length === 0 ? (
        <p class="eventi-empty">{t(lang, 'eventi.upcoming.empty')}</p>
      ) : (
        <ul class="poster-grid poster-grid-featured">
          {upcoming.map((ev, i) => (
            <li
              class={`poster-card reveal${eventStatus(ev.data) !== 'regular' ? ` is-${eventStatus(ev.data)}` : ''}`}
              style={`--reveal-delay:${(i % 6) * 0.08}s`}
              id={ev.id}
            >
              <a class="poster-link" href={`#${ev.id}`} aria-label={ev.data.artist}>
                <div class="poster-frame">
                  <img
                    src={ev.data.poster}
                    alt={`${t(lang, 'eventi.poster.alt')}, ${ev.data.artist}`}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="poster-meta">
                  {eventStatus(ev.data) !== 'regular' && (
                    <p class={`event-alert event-alert-${eventStatus(ev.data)}`} role="status">
                      <span class="event-alert-tag">{tx(statusLabel[eventStatus(ev.data) as 'cancelled' | 'postponed'], lang)}</span>
                      {eventStatusNote(ev.data, lang) && (
                        <span class="event-alert-note">{eventStatusNote(ev.data, lang)}</span>
                      )}
                    </p>
                  )}
                  <span class={`genre-badge genre-${ev.data.genre}`}>{tx(genreLabel[ev.data.genre], lang)}</span>
                  <h3>{ev.data.artist}</h3>
                  <p class="poster-when">
                    <span>{eventDateLabel(ev.data, lang)}</span>
                    <span class="dot" aria-hidden="true">·</span>
                    <span>{ev.data.time}</span>
                    {ev.data.venue && ev.data.venue !== VENUE_DEFAULT && (
                      <>
                        <span class="dot" aria-hidden="true">·</span>
                        <span>{eventVenue(ev.data, lang)}</span>
                      </>
                    )}
                  </p>
                  {eventBlurb(ev.data, lang) && <p class="poster-blurb">{eventBlurb(ev.data, lang)}</p>}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  {/* Già passati */}
  {past.length > 0 && (
    <section class="eventi-past">
      <div class="container">
        <div class="section-head">
          <h2>{t(lang, 'eventi.past.title')}</h2>
          <p>{t(lang, 'eventi.past.intro')}</p>
        </div>
        <ul class="poster-grid">
          {past.map((ev, i) => (
            <li
              class={`poster-card reveal${eventStatus(ev.data) !== 'regular' ? ` is-${eventStatus(ev.data)}` : ''}`}
              style={`--reveal-delay:${(i % 6) * 0.07}s`}
              id={ev.id}
            >
              <div class="poster-frame">
                <img
                  src={ev.data.poster}
                  alt={`${t(lang, 'eventi.poster.alt')}, ${ev.data.artist}`}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="poster-meta">
                {eventStatus(ev.data) !== 'regular' && (
                  <p class={`event-alert event-alert-${eventStatus(ev.data)}`} role="status">
                    <span class="event-alert-tag">{tx(statusLabel[eventStatus(ev.data) as 'cancelled' | 'postponed'], lang)}</span>
                    {eventStatusNote(ev.data, lang) && (
                      <span class="event-alert-note">{eventStatusNote(ev.data, lang)}</span>
                    )}
                  </p>
                )}
                <span class={`genre-badge genre-${ev.data.genre}`}>{tx(genreLabel[ev.data.genre], lang)}</span>
                <h3>{ev.data.artist}</h3>
                <p class="poster-when">
                  <span>{eventDateLabel(ev.data, lang)}</span>
                  <span class="dot" aria-hidden="true">·</span>
                  <span>{ev.data.time}</span>
                  {ev.data.venue && ev.data.venue !== VENUE_DEFAULT && (
                    <>
                      <span class="dot" aria-hidden="true">·</span>
                      <span>{eventVenue(ev.data, lang)}</span>
                    </>
                  )}
                </p>
              </div>
            </li>
          ))}
        </ul>

        <p class="follow-line">
          <a href="https://www.instagram.com/biblio_treviso/" target="_blank" rel="noopener noreferrer">
            {t(lang, 'eventi.follow')} →
          </a>
        </p>
      </div>
    </section>
  )}

  {/* Programmazione settimanale fissa: spostata in fondo, sotto "Già passati". */}
  <section class="eventi-weekly bg-paper-2">
    <div class="container">
      <div class="events-grid">
        <article class="event-card reveal">
          <p class="day">{t(lang, 'evento.gio.day')}</p>
          <h3>{t(lang, 'evento.gio.title')}</h3>
          <p class="note">{t(lang, 'evento.gio.note')}</p>
        </article>
        <article class="event-card reveal" style="--reveal-delay:.1s">
          <p class="day">{t(lang, 'evento.ven.day')}</p>
          <h3>{t(lang, 'evento.ven.title')}</h3>
          <p class="note">{t(lang, 'evento.ven.note')}</p>
        </article>
        <article class="event-card reveal" style="--reveal-delay:.2s">
          <p class="day">{t(lang, 'evento.dom.day')}</p>
          <h3>{t(lang, 'evento.dom.title')}</h3>
          <p class="note">{t(lang, 'evento.dom.note')}</p>
        </article>
      </div>
      <p class="weekly-tagline">{t(lang, 'eventi.weekly.tagline')}</p>
    </div>
  </section>

  {/* CTA finale */}
  <section class="cta-banner">
    <span class="eyebrow">{t(lang, 'eventi.cta.title')}</span>
    <h2>{t(lang, 'eventi.cta.title')}</h2>
    <p>{t(lang, 'eventi.cta.body')}</p>
    <a class="btn" href={routeMap.prenota[lang]}>{t(lang, 'eventi.cta.btn')}</a>
  </section>

  {/* Dati strutturati: ogni serata in arrivo come MusicEvent, cosi' Google puo'
      mostrarle nei risultati eventi. Solo le future (le passate non servono). */}
  {upcoming.map((ev) => (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(musicEventLd(ev, lang, siteOrigin))} />
  ))}
</section>

<!-- Scroll-reveal è gestito globalmente dal Base layout. -->

