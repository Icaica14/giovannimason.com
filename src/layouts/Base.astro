---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { type Lang, t, routeMap } from '../i18n/ui';

interface Props {
  lang: Lang;
  currentRoute: 'home' | 'truck' | 'menu' | 'eventi' | 'prenota' | 'contatti' | 'artisti';
  /** Override SEO title; default è il titolo di sito */
  title?: string;
  description?: string;
}

const { lang, currentRoute, title, description } = Astro.props;
const pageTitle = title ?? t(lang, 'site.title');
const pageDesc  = description ?? t(lang, 'site.description');

// URL assoluti per canonical, hreflang e Open Graph.
// Astro.site è settato in astro.config.mjs (placeholder fino al go-live).
const siteOrigin = Astro.site ? Astro.site.origin : '';
const itPath = routeMap[currentRoute].it;
const enPath = routeMap[currentRoute].en;
const itUrl  = `${siteOrigin}${itPath}`;
const enUrl  = `${siteOrigin}${enPath}`;
const canonicalUrl = lang === 'it' ? itUrl : enUrl;
const ogImage = `${siteOrigin}/og-default.jpg`;

// Dati strutturati: il LocalBusiness rimane lo stesso su ogni pagina,
// così Google ne ha una scheda coerente.
const ldJson = {
  '@context': 'https://schema.org',
  '@type': 'BarOrPub',
  name: 'Biblio',
  url: siteOrigin || undefined,
  image: siteOrigin ? ogImage : undefined,
  telephone: '+390422270575',
  email: 'biblio.bookcafe@gmail.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via Armando Diaz 3/A',
    postalCode: '31100',
    addressLocality: 'Treviso',
    addressRegion: 'TV',
    addressCountry: 'IT',
  },
  servesCuisine: ['Italian', 'Cocktails', 'Wine'],
  priceRange: '€€',
  // Orari coerenti con contatti.hours.body (lunedì chiuso → assente).
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Tuesday', 'Wednesday'], opens: '18:00', closes: '01:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Thursday', 'Friday', 'Saturday'], opens: '18:00', closes: '02:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Sunday', opens: '18:00', closes: '01:00' },
  ],
  sameAs: ['https://www.instagram.com/biblio_treviso/'],
};

// Toggle labels mobile menu, passati al client via data attribute.
const menuOpenLabel  = t(lang, 'nav.menu.toggle');
const menuCloseLabel = t(lang, 'nav.menu.close');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="it" href={itUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={itUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'it' ? 'it_IT' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'it' ? 'en_US' : 'it_IT'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Biblio" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#f6efe1" />
    <link rel="icon" href="/favicon.svg?v=2" type="image/svg+xml" />
    <!-- Google Fonts: Cormorant Garamond (display) + Lora (body) + Cinzel (brand) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Lora:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(ldJson)}
    ></script>
  </head>
  <body data-menu-open-label={menuOpenLabel} data-menu-close-label={menuCloseLabel}>
    <a class="skip-link" href="#main">{t(lang, 'a11y.skip')}</a>
    <Nav lang={lang} currentRoute={currentRoute} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <script>
      // Toggle mobile nav, anche aria-label commuta fra "apri" / "chiudi".
      const navEl = document.querySelector<HTMLElement>('.nav');
      const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
      const body = document.body;
      const openLabel  = body.dataset.menuOpenLabel  ?? 'Open menu';
      const closeLabel = body.dataset.menuCloseLabel ?? 'Close menu';
      toggle?.addEventListener('click', () => {
        const open = navEl?.classList.toggle('is-open') ?? false;
        toggle.setAttribute('aria-expanded', String(open));
        toggle.setAttribute('aria-label', open ? closeLabel : openLabel);
      });

      // Scroll-reveal globale: ogni elemento con `.reveal` riceve `.is-visible`
      // quando entra in viewport. Pattern unico, applicato dal Base layout per
      // qualunque pagina. CSS rispetta prefers-reduced-motion (in global.css).
      const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
      if (revealEls.length > 0) {
        if ('IntersectionObserver' in window) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  io.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
          );
          revealEls.forEach((el) => io.observe(el));
        } else {
          revealEls.forEach((el) => el.classList.add('is-visible'));
        }
      }
    </script>
  </body>
</html>
