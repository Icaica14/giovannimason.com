---
import Base from '../../layouts/Base.astro';
import HomePage from '../../components/HomePage.astro';
import { t } from '../../i18n/ui';

// La Home non è più la pagina iniziale del dominio: `/` reindirizza al Biblio
// Truck (vedi redirects in astro.config.mjs). La Home vive qui, su /home/, ed è
// raggiungibile da nav, brand e footer (routeMap.home).
const lang = 'it' as const;
---

<Base
  lang={lang}
  currentRoute="home"
  title={t(lang, 'home.meta.title')}
  description={t(lang, 'home.meta.description')}
>
  <HomePage lang={lang} />
</Base>
