---
import Base from '../layouts/Base.astro';
import TruckPage from '../components/TruckPage.astro';
import { t } from '../i18n/ui';

const lang = 'it' as const;
---

<Base
  lang={lang}
  currentRoute="truck"
  title={t(lang, 'truck.meta.title')}
  description={t(lang, 'truck.meta.description')}
>
  <TruckPage lang={lang} />
</Base>
