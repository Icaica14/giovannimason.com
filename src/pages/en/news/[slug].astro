---
import Base from '../../../layouts/Base.astro';
import NewsDetail from '../../../components/NewsDetail.astro';
import { getNews } from '../../../data/newsRemote';
import { publishedNews, newsTitle, newsExcerpt } from '../../../data/news';
import { routeMap } from '../../../i18n/ui';

export async function getStaticPaths() {
  const items = publishedNews(await getNews());
  return items.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const lang = 'en' as const;
const { entry } = Astro.props;
const title = newsTitle(entry.data, lang);
const description = newsExcerpt(entry.data, lang, 160);
const itPath = `${routeMap.news.it}${entry.slug}/`;
const enPath = `${routeMap.news.en}${entry.slug}/`;
---

<Base
  lang={lang}
  currentRoute="news"
  title={`${title} · Biblio`}
  description={description}
  itPath={itPath}
  enPath={enPath}
>
  <NewsDetail lang={lang} entry={entry} />
</Base>
