---
// Radice del dominio (/) = Home del bar Biblio.
// La pagina Biblio Truck vive su /biblio-truck/ (raggiungibile da nav e link).
// Il vecchio /home/ reindirizza qui (vedi astro.config).
import Base from '../layouts/Base.astro';
import HomePage from '../components/HomePage.astro';
import { t } from '../i18n/ui';

const lang = 'it' as const;
---

<Base
  lang={lang}
  currentRoute="home"
  title={t(lang, 'home.meta.title')}
  description={t(lang, 'home.meta.description')}
>
  <HomePage lang={lang} />
</Base>
