---
// Radice del dominio (/) = pagina Biblio Truck, servita DIRETTAMENTE (indicizzabile).
// Scelta del proprietario: il dominio apre sul Biblio Truck. La Home "classica"
// resta su /home/. Il vecchio URL /biblio-truck/ reindirizza qui (vedi astro.config).
import Base from '../layouts/Base.astro';
import TruckPage from '../components/TruckPage.astro';
import { t } from '../i18n/ui';

const lang = 'it' as const;
---

<Base
  lang={lang}
  currentRoute="truck"
  title={t(lang, 'truck.meta.title')}
  description={t(lang, 'truck.meta.description')}
>
  <TruckPage lang={lang} />
</Base>
