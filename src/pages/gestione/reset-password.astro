---
// Reset password dell'app gestione — pagina pubblica (l'utente arriva dal link
// email), ma NON concede accesso: dopo il cambio password si verifica comunque
// l'autorizzazione admin (vedi ResetPasswordPanel + checkAdmin + RLS Supabase).
// Stesso layout minimale di /gestione: noindex, fuori da nav/SEO/sitemap.
import ResetPasswordPanel from '../../components/gestione/ResetPasswordPanel';
import '../../styles/gestione.css';

const supabaseConfigured =
  Boolean(import.meta.env.PUBLIC_SUPABASE_URL) &&
  Boolean(import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Reimposta password · Biblio</title>
    <link rel="icon" href="/favicon.svg?v=2" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&display=swap"
    />
  </head>
  <body>
    {
      supabaseConfigured ? (
        <ResetPasswordPanel client:only="preact" />
      ) : (
        <div class="g-center">
          <div class="g-login">
            <div class="g-brand">
              Biblio
              <small>Gestione</small>
            </div>
            <div class="g-msg g-msg-err">
              Supabase non è configurato. Imposta
              <code>PUBLIC_SUPABASE_URL</code> e
              <code>PUBLIC_SUPABASE_ANON_KEY</code>.
            </div>
          </div>
        </div>
      )
    }
  </body>
</html>
